        "collapsible_tab_mjEF8T": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Description",
            "icon": "none",
            "content": "<p>Huuha Queen™ Slippery Huuha is a daily gummy that <strong>restores your body's natural moisture, balances your pH, and keeps everything fresh</strong> — from the inside out.</p><p>No creams. No suppositories. No mess. Just two gummies a day with the three things your body actually needs:</p><ul><li>Slippery elm for <strong>moisture</strong></li><li>Probiotics for <strong>balance</strong></li><li>Real pineapple for <strong>freshness</strong></li></ul>",
            "page": ""
          }
        },
        "collapsible_tab_gBgAbF": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Why you need Huuha Queen® Slippery Huuha?",
            "icon": "none",
            "content": "<p>If you've been dealing with <strong>dryness</strong>, <strong>odor</strong>, or <strong>pH problems that keep coming back</strong> — and you're tired of the creams that leaked, the pills that did nothing, and the treatments that made things worse — <strong>Huuha Queen™ was made for you.</strong></p><p>Huuha Queen works from the inside.</p><p>No applicators. No discharge. No more guessing which product might be the one. </p><p>Just two gummies. That's it.</p>",
            "page": ""
          }
        },
        "collapsible_tab_akEwJj": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Benefits 🌸",
            "icon": "none",
            "content": "<p>✓ <strong>Works with your body —</strong> no hormones, no estrogen, no mess</p><p><strong>✓ Protects against BV, UTI, and yeast</strong></p><p><strong>✓ Balances pH</strong> so infections stop coming back</p><p><strong>✓ Restores natural moisture —</strong> no fake wetness, your body's own</p><p><strong>✓ Eliminates odor from the inside —</strong> not a cover-up</p><p><strong>✓ Supports healthy flora</strong> so your body stays balanced</p>",
            "page": ""
          }
        },
        "collapsible_tab_MTCgw9": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Recommended Use",
            "icon": "none",
            "content": "<p>Take <strong>2 gummies a day</strong> with food. That's it. Most women start noticing changes within the first 1-2 weeks.</p><p>Full results build over <strong>30 days of daily use</strong>. Stick with it — your body needs time to reset.</p>",
            "page": ""
          }
        },
        "collapsible_tab_FPPE7p": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Do you offer a guarantee?",
            "icon": "none",
            "content": "<p>Yes! All orders come with a <strong>30-day money-back guarantee.</strong></p><p>If you don't feel a real difference in your body — more moisture, less odor, better balance — just reach out and we'll refund you. No hoops. No questions.</p><p>You've spent enough money on things that didn't work. This one is risk-free.</p>",
            "page": ""
          }
        },
