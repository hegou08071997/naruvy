            "navigation_title": "Transparency",
            "desktop_image_position": "left",
            "image_aspect_ratio": "adapt",
            "heading": "Responsible Labeling Standards",
            "highlight_style": "none",
            "highlight_font_style": "italic",
            "highlight_style_color": "",
            "highlight_text_color": "",
            "heading_size": "h2",
            "subheading": "",
            "description": "<p>We ensure our product labels are honest, accurate, and never misleading. All claims on our packaging are backed by science, and we avoid greenwashing by steering clear of vague or unverified sustainability language. From ingredient sourcing to efficacy statements, our labeling practices are rooted in clarity, ethics, and full regulatory compliance.</p>",
            "description_size": "text-base",
            "button_label": "",
            "button_link": "",
            "button_style": "btn--primary",
            "button_icon": "none"
