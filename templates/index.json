dth:100%;height:100%;object-fit:cover;border-radius:16px\"></div><span class=\"chefsy-cat-label\">Cookware</span></div><div class=\"chefsy-category-card\"><div class=\"chefsy-cat-img\" style=\"background:linear-gradient(135deg,#1B4332,#2D6A4F)\"><img src=\"{{ 'collage-main.jpg' | asset_url }}\" alt=\"Cleaning\" style=\"width:100%;height:100%;object-fit:cover;border-radius:16px\"></div><span class=\"chefsy-cat-label\">Cleaning</span></div></div></div></section><script>var track=document.getElementById('chefsy-cat-track');var prev=document.getElementById('cat-prev');var next=document.getElementById('cat-next');var scrollAmt=280;if(next)next.addEventListener('click',function(){track.scrollBy({left:scrollAmt,behavior:'smooth'});});if(prev)prev.addEventListener('click',function(){track.scrollBy({left:-scrollAmt,behavior:'smooth'});});</script>",
