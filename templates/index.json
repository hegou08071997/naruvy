    "testimonials": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<section class=\"chefsy-testimonials\"><div class=\"page-width\"><h2 class=\"chefsy-testimonials__title\">What Our Customers Say</h2><div class=\"chefsy-testimonials__grid\"><div class=\"chefsy-review-card\"><div class=\"chefsy-review-stars\">★★★★★</div><p class=\"chefsy-review-text\">\"These pots changed my entire cooking routine. The coating is incredible — nothing sticks and cleanup is so easy. Highly recommend!\"</p><div class=\"chefsy-review-author\"><div class=\"chefsy-review-avatar\">SM</div><div><strong>Sarah M.</strong><span>Verified Buyer · New York</span></div></div></div><div class=\"chefsy-review-card\"><div class=\"chefsy-review-stars\">★★★★★</div><p class=\"chefsy-review-text\">\"Finally a brand that actually cares about quality without sacrificing style. The utensil set is beautiful and so durable. Already bought three sets as gifts!\"</p><div class=\"chefsy-review-author\"><div class=\"chefsy-review-avatar\">JT</div><div><strong>James T.</strong><span>Verified Buyer · California</span></div></div></div><div class=\"chefsy-review-card\"><div class=\"chefsy-review-stars\">★★★★★</div><p class=\"chefsy-review-text\">\"Homerline is my go-to for all kitchen gifts. The quality is top-notch, and they arrive so beautifully presented. My kitchen has never looked better!\"</p><div class=\"chefsy-review-author\"><div class=\"chefsy-review-avatar\">AL</div><div><strong>Anika L.</strong><span>Verified Buyer · London</span></div></div></div></div></div></section>",
