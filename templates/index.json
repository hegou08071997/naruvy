            "button_link": "shopify://collections/all"
          }
        },
        "row_3": {
          "type": "row",
          "settings": {
            "caption": "Our Community",
            "heading": "Trusted by 50,000+ eco-conscious homes",
            "text": "<p>From small studio apartments to large family kitchens, Homerline products are trusted by people who care about the planet and love beautiful design. Join our growing community.</p>",
