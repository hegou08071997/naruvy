    "why_us": {
      "type": "multirow",
      "blocks": {
        "row_1": {
          "type": "row",
          "settings": {
            "caption": "Our Promise",
            "heading": "Materials that respect nature",
            "text": "<p>Every Homerline product begins with a simple question: is this good for the earth? We source bamboo, recycled metals, and plant-based coatings that keep your kitchen clean and our planet healthy.</p>",
            "button_label": "Shop Materials",
            "button_link": "shopify://collections/all"
          }
        },
        "row_2": {
          "type": "row",
          "settings": {
            "caption": "Design Philosophy",
            "heading": "Timeless design, built to last",
            "text": "<p>We reject fast trends. Our designs are timeless — built with high-quality construction that lasts decades, not seasons. Buy less. Buy better. That's the Homerline way.</p>",
