{%- comment -%}
  Premium per-lesson emblems for the Gristle Vault opt-in page.
  Each is a unique inline SVG mark (not an icon-library glyph).
  Usage: {% render 'vault-emblem', key: 'pick' %}
  Keys: pick travis chords outside tone blues song clinic pdf
{%- endcomment -%}
{%- assign k = key | default: 'pick' -%}
<span class="vopt-emblem" aria-hidden="true">
{%- case k -%}
{%- when 'pick' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="32" cy="32" r="26" stroke="#3a2410" stroke-width="3"/>
    <circle cx="32" cy="32" r="26" stroke="#e8853a" stroke-width="1.4" stroke-dasharray="2.5 4.5" opacity="0.55"/>
    <path d="M22 22 Q32 17 42 22 Q39.5 39 32 47 Q24.5 39 22 22 Z" fill="#c8601a" stroke="#f0a35c" stroke-width="1.6"/>
    <path d="M27 27 Q32 24.5 37 27" stroke="#1a0f06" stroke-width="1.6" stroke-linecap="round" opacity="0.5"/>
  </svg>
{%- when 'travis' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#6a4a2a" stroke-width="2">
      <line x1="12" y1="20" x2="52" y2="20"/><line x1="12" y1="28" x2="52" y2="28"/>
      <line x1="12" y1="36" x2="52" y2="36"/><line x1="12" y1="44" x2="52" y2="44"/>
    </g>
    <path d="M22 20 q3.5 6 0 11" stroke="#f0a35c" stroke-width="1.6" opacity="0.7" fill="none"/>
    <path d="M34 36 q3.5 6 0 11" stroke="#f0a35c" stroke-width="1.6" opacity="0.7" fill="none"/>
    <g fill="#e8853a"><circle cx="22" cy="20" r="4.2"/><circle cx="34" cy="36" r="4.2"/><circle cx="46" cy="28" r="4.2"/></g>
  </svg>
{%- when 'chords' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#6a4a2a" stroke-width="2">
      <line x1="20" y1="15" x2="20" y2="49"/><line x1="28" y1="15" x2="28" y2="49"/>
      <line x1="36" y1="15" x2="36" y2="49"/><line x1="44" y1="15" x2="44" y2="49"/>
      <line x1="16" y1="23" x2="48" y2="23"/><line x1="16" y1="32" x2="48" y2="32"/><line x1="16" y1="41" x2="48" y2="41"/>
    </g>
    <g fill="#e8853a" stroke="#f0a35c" stroke-width="1.2">
      <circle cx="28" cy="27.5" r="4.4"/><circle cx="36" cy="36.5" r="4.4"/><circle cx="44" cy="27.5" r="4.4"/>
    </g>
  </svg>
{%- when 'outside' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#6a4a2a" stroke-width="2">
      <line x1="12" y1="26" x2="52" y2="26"/><line x1="12" y1="32" x2="52" y2="32"/>
      <line x1="12" y1="38" x2="52" y2="38"/><line x1="12" y1="44" x2="52" y2="44"/>
    </g>
    <circle cx="22" cy="44" r="3.4" fill="#8a6a4a"/>
    <circle cx="32" cy="38" r="3.4" fill="#8a6a4a"/>
    <line x1="49" y1="13" x2="49" y2="36" stroke="#e8853a" stroke-width="2"/>
    <circle cx="46" cy="14" r="5" fill="#e8853a" stroke="#f0a35c" stroke-width="1.5"/>
  </svg>
{%- when 'tone' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="32" cy="33" r="19" fill="#1c1c1c" stroke="#6a4a2a" stroke-width="2.5"/>
    <circle cx="32" cy="33" r="12" fill="#262626" stroke="#4a4038" stroke-width="1"/>
    <line x1="32" y1="33" x2="32" y2="22" stroke="#e8853a" stroke-width="3" stroke-linecap="round"/>
    <g stroke="#8a6a4a" stroke-width="2" stroke-linecap="round">
      <line x1="15" y1="45" x2="18" y2="42"/><line x1="49" y1="45" x2="46" y2="42"/>
      <line x1="11" y1="31" x2="15" y2="31"/><line x1="53" y1="31" x2="49" y2="31"/>
    </g>
  </svg>
{%- when 'blues' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M9 46 H55" stroke="#5a4030" stroke-width="2" stroke-dasharray="2 4"/>
    <path d="M9 40 C 26 40, 30 18, 55 18" stroke="#e8853a" stroke-width="3" fill="none" stroke-linecap="round"/>
    <path d="M48 11 L57 18 L48 25" stroke="#f0a35c" stroke-width="2.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
{%- when 'song' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="12" y="19" width="40" height="26" rx="2.5" fill="#1a1a1a" stroke="#6a4a2a" stroke-width="2"/>
    <g fill="#3a2410"><rect x="14.5" y="21.5" width="3" height="3" rx="0.6"/><rect x="14.5" y="40.5" width="3" height="3" rx="0.6"/><rect x="46.5" y="21.5" width="3" height="3" rx="0.6"/><rect x="46.5" y="40.5" width="3" height="3" rx="0.6"/></g>
    <g stroke="#e8853a" stroke-width="2.2" stroke-linecap="round">
      <line x1="22" y1="32" x2="22" y2="37"/><line x1="26" y1="28" x2="26" y2="41"/><line x1="30" y1="31" x2="30" y2="38"/>
      <line x1="34" y1="26" x2="34" y2="43"/><line x1="38" y1="30" x2="38" y2="39"/><line x1="42" y1="28" x2="42" y2="41"/>
    </g>
  </svg>
{%- when 'clinic' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="26" y="11" width="12" height="25" rx="6" fill="#262626" stroke="#e8853a" stroke-width="2"/>
    <g stroke="#8a6a4a" stroke-width="1.4"><line x1="29" y1="17" x2="35" y2="17"/><line x1="29" y1="22" x2="35" y2="22"/><line x1="29" y1="27" x2="35" y2="27"/></g>
    <path d="M20 29 a12 12 0 0 0 24 0" fill="none" stroke="#e8853a" stroke-width="2.5"/>
    <line x1="32" y1="41" x2="32" y2="50" stroke="#8a6a4a" stroke-width="2.5"/>
    <line x1="24" y1="50" x2="40" y2="50" stroke="#8a6a4a" stroke-width="2.5" stroke-linecap="round"/>
    <g stroke="#f0a35c" stroke-width="1.5" opacity="0.55" fill="none"><path d="M46 20 a9 9 0 0 1 0 18"/><path d="M50 15 a15 15 0 0 1 0 28"/></g>
  </svg>
{%- when 'pdf' -%}
  <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M13 19 h13 l4 5 h21 a2 2 0 0 1 2 2 v20 a2 2 0 0 1 -2 2 H13 a2 2 0 0 1 -2 -2 V21 a2 2 0 0 1 2 -2 z" fill="#1a1a1a" stroke="#6a4a2a" stroke-width="2"/>
    <line x1="18" y1="33" x2="33" y2="33" stroke="#8a6a4a" stroke-width="2" stroke-linecap="round"/>
    <line x1="18" y1="39" x2="28" y2="39" stroke="#5a4030" stroke-width="2" stroke-linecap="round"/>
    <circle cx="42" cy="40" r="8" fill="#c8601a" stroke="#f0a35c" stroke-width="1.6"/>
    <path d="M38.5 40 l2.5 2.5 4.5 -4.8" stroke="#1a0f06" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
{%- endcase -%}
</span>
