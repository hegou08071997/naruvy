{%- comment -%}
  Per-lesson hero composition for the Gristle Vault lesson cards.
  Renders the supporting graphics that frame the (separate) central
  play button. Each lesson has its own silhouette + composition.
  Usage: {% render 'vault-scene', key: 'pick' %}
  Keys: pick travis chords outside tone blues song clinic
{%- endcomment -%}
{%- assign k = key | default: 'pick' -%}
<span class="vopt-scene-art vopt-scene-art--{{ k }}" aria-hidden="true">
{%- case k -%}
{%- when 'pick' -%}
  <svg viewBox="0 0 320 118" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <defs><linearGradient id="vpk" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#f3ad6a"/><stop offset="1" stop-color="#9a4910"/></linearGradient></defs>
    <path d="M116 26 Q160 12 204 26 Q197 72 160 100 Q123 72 116 26 Z" fill="#e8853a" opacity="0.05"/>
    <path d="M116 26 Q160 12 204 26 Q197 72 160 100 Q123 72 116 26 Z" fill="none" stroke="url(#vpk)" stroke-width="2.4"/>
    <g class="vopt-streak" stroke="#e8853a" stroke-linecap="round">
      <line x1="40" y1="40" x2="84" y2="33" stroke-width="3" opacity="0.55"/>
      <line x1="36" y1="58" x2="76" y2="53" stroke-width="2" opacity="0.4"/>
      <line x1="236" y1="64" x2="280" y2="57" stroke-width="3" opacity="0.55"/>
      <line x1="244" y1="82" x2="284" y2="78" stroke-width="2" opacity="0.4"/>
    </g>
  </svg>
{%- when 'travis' -%}
  <svg viewBox="0 0 320 118" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#5a4030" stroke-width="1.5">
      <line x1="22" y1="28" x2="298" y2="28"/><line x1="22" y1="39" x2="298" y2="39"/><line x1="22" y1="50" x2="298" y2="50"/>
      <line x1="22" y1="61" x2="298" y2="61"/><line x1="22" y1="72" x2="298" y2="72"/><line x1="22" y1="83" x2="298" y2="83"/>
    </g>
    <g fill="#e8853a">
      <circle cx="54" cy="39" r="4"/><circle cx="88" cy="72" r="4"/><circle cx="120" cy="50" r="3.4" opacity="0.7"/>
      <circle cx="206" cy="61" r="4"/><circle cx="242" cy="28" r="4"/><circle cx="278" cy="50" r="3.4" opacity="0.7"/>
    </g>
  </svg>
{%- when 'chords' -%}
  <svg viewBox="0 0 320 118" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#5a4030" stroke-width="1.5">
      <line x1="44" y1="24" x2="44" y2="88"/><line x1="70" y1="24" x2="70" y2="88"/><line x1="96" y1="24" x2="96" y2="88"/><line x1="122" y1="24" x2="122" y2="88"/>
      <line x1="32" y1="36" x2="134" y2="36"/><line x1="32" y1="56" x2="134" y2="56"/><line x1="32" y1="76" x2="134" y2="76"/>
    </g>
    <path d="M70 46 L122 46 L96 66 Z" fill="none" stroke="#e8853a" stroke-width="1.3" opacity="0.5"/>
    <g fill="#e8853a" stroke="#f0a35c" stroke-width="1"><circle cx="70" cy="46" r="4.6"/><circle cx="122" cy="46" r="4.6"/><circle cx="96" cy="66" r="4.6"/></g>
    <g stroke="#e8853a" stroke-width="1.4" opacity="0.4"><line x1="210" y1="40" x2="266" y2="40"/><line x1="210" y1="56" x2="280" y2="56"/><line x1="210" y1="72" x2="258" y2="72"/></g>
  </svg>
{%- when 'outside' -%}
  <svg viewBox="0 0 320 118" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#5a4030" stroke-width="1.5">
      <line x1="26" y1="38" x2="294" y2="38"/><line x1="26" y1="48" x2="294" y2="48"/><line x1="26" y1="58" x2="294" y2="58"/><line x1="26" y1="68" x2="294" y2="68"/><line x1="26" y1="78" x2="294" y2="78"/>
    </g>
    <g fill="#6a5038"><circle cx="66" cy="68" r="4"/><circle cx="102" cy="58" r="4"/><circle cx="222" cy="48" r="4"/></g>
    <path d="M248 58 q12 -34 40 -40" fill="none" stroke="#e8853a" stroke-width="1.4" stroke-dasharray="3 4" opacity="0.6"/>
    <circle class="vopt-escape" cx="288" cy="18" r="6.2" fill="#e8853a" stroke="#f0a35c" stroke-width="1.6"/>
  </svg>
{%- when 'tone' -%}
  <svg viewBox="0 0 320 118" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g transform="translate(160,55)">
      <circle r="46" fill="#e8853a" opacity="0.04"/>
      <circle r="44" fill="none" stroke="#5a4030" stroke-width="2"/>
      <circle r="31" fill="none" stroke="#6a4a2a" stroke-width="1.4" opacity="0.7"/>
      <g stroke="#6a4a2a" stroke-width="2" stroke-linecap="round">
        <line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(0)"/><line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(30)"/>
        <line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(60)"/><line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(90)"/>
        <line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(120)"/><line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(150)"/>
        <line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(210)"/><line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(240)"/>
        <line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(270)"/><line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(300)"/>
        <line x1="0" y1="-50" x2="0" y2="-44" transform="rotate(330)"/>
      </g>
      <line x1="0" y1="-31" x2="0" y2="-50" stroke="#e8853a" stroke-width="3" stroke-linecap="round"/>
    </g>
  </svg>
{%- when 'blues' -%}
  <svg viewBox="0 0 320 118" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M18 84 C 92 84, 120 26, 302 20" stroke="#e8853a" stroke-width="3" stroke-linecap="round"/>
    <path d="M18 92 C 100 92, 126 38, 302 32" stroke="#e8853a" stroke-width="1.4" opacity="0.32"/>
    <path d="M18 76 C 84 76, 112 18, 296 12" stroke="#e8853a" stroke-width="1.2" opacity="0.22"/>
    <path d="M288 11 l15 8 -10 11" fill="none" stroke="#f0a35c" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
{%- when 'song' -%}
  <svg viewBox="0 0 320 118" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="26" y1="84" x2="294" y2="84" stroke="#5a4030" stroke-width="2"/>
    <g stroke="#6a4a2a" stroke-width="2" stroke-linecap="round">
      <line x1="60" y1="78" x2="60" y2="90"/><line x1="126" y1="78" x2="126" y2="90"/><line x1="194" y1="78" x2="194" y2="90"/><line x1="260" y1="78" x2="260" y2="90"/>
    </g>
    <g fill="#e8853a"><rect x="86" y="80" width="7" height="7" rx="1" transform="rotate(45 89.5 83.5)"/><rect x="160" y="80" width="7" height="7" rx="1" transform="rotate(45 163.5 83.5)"/><rect x="227" y="80" width="7" height="7" rx="1" transform="rotate(45 230.5 83.5)"/></g>
    <g stroke="#e8853a" stroke-width="2" stroke-linecap="round" opacity="0.5"><line x1="96" y1="26" x2="96" y2="42"/><line x1="160" y1="22" x2="160" y2="40"/><line x1="224" y1="26" x2="224" y2="42"/></g>
  </svg>
{%- when 'clinic' -%}
  <svg viewBox="0 0 320 118" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g transform="translate(160,54)">
      <rect x="-27" y="-35" width="54" height="64" rx="27" fill="#e8853a" opacity="0.04"/>
      <rect x="-27" y="-35" width="54" height="64" rx="27" fill="none" stroke="#6a4a2a" stroke-width="2"/>
      <g stroke="#5a4030" stroke-width="1.4"><line x1="-18" y1="-22" x2="18" y2="-22"/><line x1="-20" y1="-12" x2="20" y2="-12"/><line x1="-20" y1="-2" x2="20" y2="-2"/><line x1="-20" y1="8" x2="20" y2="8"/><line x1="-18" y1="18" x2="18" y2="18"/></g>
    </g>
    <g class="vopt-rings" fill="none" stroke="#e8853a" stroke-linecap="round">
      <path d="M212 36 a24 24 0 0 1 0 38" stroke-width="2.4" opacity="0.6"/><path d="M226 25 a36 36 0 0 1 0 60" stroke-width="2" opacity="0.4"/><path d="M240 14 a48 48 0 0 1 0 82" stroke-width="1.6" opacity="0.24"/>
      <path d="M108 36 a24 24 0 0 0 0 38" stroke-width="2.4" opacity="0.6"/><path d="M94 25 a36 36 0 0 0 0 60" stroke-width="2" opacity="0.4"/><path d="M80 14 a48 48 0 0 0 0 82" stroke-width="1.6" opacity="0.24"/>
    </g>
  </svg>
{%- endcase -%}
</span>
