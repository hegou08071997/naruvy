{%- if settings.custom_font_enabled -%}
  <style>
    @font-face {
      font-family: 'Clash Grotesk Medium';
      src: url('{{ 'ClashGrotesk-Variable.woff2' | asset_url }}') format('woff2'),
           url('{{ 'ClashGrotesk-Variable.woff' | asset_url }}') format('woff');
      font-weight: 200 700;
      font-display: swap;
      font-style: normal;
    }

    @font-face {
      font-family: 'Satoshi';
      src: url('{{ 'Satoshi-Variable.woff2' | asset_url }}') format('woff2'),
           url('{{ 'Satoshi-Variable.woff' | asset_url }}') format('woff');
      font-weight: 300 900;
      font-display: swap;
      font-style: normal;
    }

    :root {
      --font-heading-family: 'Clash Grotesk Medium', sans-serif;
      --font-heading-style: normal;
      --font-heading-weight: 500;

      --font-body-family: 'Satoshi', sans-serif;
      --font-body-style: normal;
      --font-body-weight: {{ settings.custom_font_body_weight }};
    }
  </style>
{%- endif -%}
