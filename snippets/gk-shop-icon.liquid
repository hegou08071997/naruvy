{% comment %}
  GK Shop category icons — inline SVG, 24x24 viewBox, orange stroke via CSS.
  Animated subparts carry .gk-ico__* classes (animations live in the section CSS).
  Param: icon = new | cds | vinyl | merch | gear | books | dvds
{% endcomment %}

{%- case icon -%}

{%- when 'new' -%}
  <svg class="gk-ico" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path class="gk-ico__star" d="M12 3.2l2.45 4.96 5.47.8-3.96 3.86.94 5.45L12 15.9l-4.9 2.57.94-5.45L4.08 9.0l5.47-.8L12 3.2z"
      stroke="currentColor" fill="rgba(200,96,26,0.12)"/>
  </svg>

{%- when 'cds' -%}
  <svg class="gk-ico" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <!-- jewel case -->
    <rect x="3.5" y="3.5" width="17" height="17" rx="1.5" stroke="currentColor"/>
    <!-- hinge spine on the left -->
    <line x1="6.5" y1="3.5" x2="6.5" y2="20.5" stroke="currentColor" opacity="0.7"/>
    <!-- spinning disc -->
    <g class="gk-ico__cdDisc">
      <circle cx="14" cy="12" r="6" stroke="currentColor"/>
      <circle cx="14" cy="12" r="1.4" stroke="currentColor"/>
      <!-- reflective arc highlight -->
      <path d="M10.6 7.4a6 6 0 0 1 5.6-0.2" stroke="currentColor" opacity="0.55"/>
    </g>
  </svg>

{%- when 'vinyl' -%}
  <svg class="gk-ico" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <!-- spinning record with grooves + orange label -->
    <g class="gk-ico__vinylDisc">
      <circle cx="11" cy="12" r="8" stroke="currentColor"/>
      <circle cx="11" cy="12" r="6" stroke="currentColor" opacity="0.45"/>
      <circle cx="11" cy="12" r="4" stroke="currentColor" opacity="0.45"/>
      <circle cx="11" cy="12" r="2.1" fill="rgba(200,96,26,0.85)" stroke="none"/>
      <circle cx="11" cy="12" r="0.5" fill="#0d0d0d" stroke="none"/>
    </g>
    <!-- tonearm + cartridge, swaying -->
    <g class="gk-ico__vinylArm">
      <line x1="20" y1="4" x2="13.4" y2="10.2" stroke="currentColor"/>
      <circle cx="20" cy="4" r="1.1" stroke="currentColor"/>
      <rect x="12.2" y="9.4" width="2.2" height="2.2" rx="0.4" transform="rotate(45 13.3 10.5)" stroke="currentColor"/>
    </g>
  </svg>

{%- when 'merch' -%}
  <svg class="gk-ico" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <g class="gk-ico__shirt">
      <path d="M8.5 3.5L4 6.2l1.8 3 1.7-1V20.5h9V8.2l1.7 1 1.8-3-4.5-2.7a3 3 0 0 1-6 0z"
        stroke="currentColor" fill="rgba(200,96,26,0.08)"/>
    </g>
  </svg>

{%- when 'gear' -%}
  {%- comment -%} Horizontal S-style (Stratocaster) electric guitar: body right, headstock left {%- endcomment -%}
  <svg class="gk-ico" viewBox="0 0 24 24" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <g class="gk-ico__guitar">
      <!-- 6-in-line headstock (far left), tuners along top edge -->
      <path d="M3.6 10.9L1.3 9.9c-0.7-0.3-0.9 0.9-0.3 1.2l2.6 1.4z" stroke="currentColor" fill="rgba(200,96,26,0.12)"/>
      <circle cx="1.5" cy="9.9" r="0.32" fill="currentColor" stroke="none"/>
      <circle cx="2.1" cy="10.15" r="0.32" fill="currentColor" stroke="none"/>
      <circle cx="2.7" cy="10.4" r="0.32" fill="currentColor" stroke="none"/>

      <!-- bolt-on neck with frets -->
      <path d="M3.6 11.1h9.2v1.9H3.6z" stroke="currentColor"/>
      <line x1="6.0" y1="11.1" x2="6.0" y2="13.0" stroke="currentColor" opacity="0.6"/>
      <line x1="8.0" y1="11.1" x2="8.0" y2="13.0" stroke="currentColor" opacity="0.6"/>
      <line x1="10.0" y1="11.1" x2="10.0" y2="13.0" stroke="currentColor" opacity="0.6"/>
      <!-- fret markers -->
      <circle cx="7.0" cy="12.05" r="0.3" fill="currentColor" stroke="none"/>
      <circle cx="9.0" cy="12.05" r="0.3" fill="currentColor" stroke="none"/>

      <!-- offset double-cutaway body (two horns face the neck) -->
      <path d="M12.8 11.1
               C12.8 9.4 13.6 8.0 15.3 8.0
               C16.3 8.0 16.9 8.8 17.4 9.7
               C18.0 8.5 19.3 7.9 20.7 8.1
               C22.4 8.4 23.2 10.0 23.2 12.05
               C23.2 14.1 22.4 15.7 20.7 16.0
               C19.3 16.2 18.0 15.6 17.4 14.4
               C16.9 15.3 16.3 16.1 15.3 16.1
               C13.6 16.1 12.8 14.7 12.8 13.0 Z"
        stroke="currentColor" fill="rgba(200,96,26,0.08)"/>

      <!-- pickups -->
      <rect x="16.5" y="10.7" width="0.9" height="2.7" rx="0.3" stroke="currentColor"/>
      <rect x="18.1" y="10.7" width="0.9" height="2.7" rx="0.3" stroke="currentColor"/>
      <!-- bridge -->
      <rect x="20.0" y="11.0" width="1.0" height="2.1" rx="0.3" stroke="currentColor"/>

      <!-- vibrating strings: headstock across neck to bridge -->
      <g class="gk-ico__strings">
        <line x1="1.6" y1="11.5" x2="20.2" y2="11.6" stroke="currentColor" opacity="0.85"/>
        <line x1="1.6" y1="12.05" x2="20.2" y2="12.05" stroke="currentColor" opacity="0.85"/>
        <line x1="1.6" y1="12.6" x2="20.2" y2="12.5" stroke="currentColor" opacity="0.85"/>
      </g>
    </g>
  </svg>

{%- when 'books' -%}
  <svg class="gk-ico" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="perspective:300px;">
    <!-- back cover -->
    <path d="M6 4h11a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H6z" stroke="currentColor" opacity="0.5"/>
    <!-- inner page lines revealed when cover opens -->
    <line x1="8.5" y1="8" x2="14.5" y2="8" stroke="currentColor" opacity="0.6"/>
    <line x1="8.5" y1="11" x2="14.5" y2="11" stroke="currentColor" opacity="0.6"/>
    <line x1="8.5" y1="14" x2="13" y2="14" stroke="currentColor" opacity="0.6"/>
    <!-- orange spine -->
    <rect x="5" y="4" width="1.6" height="16" rx="0.4" fill="rgba(200,96,26,0.85)" stroke="none"/>
    <!-- flipping front cover -->
    <g class="gk-ico__bookCover">
      <path d="M6 4h11a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H6z" stroke="currentColor" fill="rgba(200,96,26,0.12)"/>
    </g>
  </svg>

{%- when 'dvds' -%}
  <svg class="gk-ico" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <!-- disc case -->
    <rect x="3.5" y="3.5" width="17" height="17" rx="1.5" stroke="currentColor"/>
    <line x1="6.5" y1="3.5" x2="6.5" y2="20.5" stroke="currentColor" opacity="0.7"/>
    <!-- pulsing rings -->
    <g class="gk-ico__dvdRings">
      <circle cx="13.5" cy="12" r="6" stroke="currentColor"/>
      <circle cx="13.5" cy="12" r="3.4" stroke="currentColor" opacity="0.7"/>
    </g>
    <!-- play triangle -->
    <path d="M12.4 9.8l3.4 2.2-3.4 2.2z" fill="rgba(200,96,26,0.9)" stroke="none"/>
  </svg>

{%- else -%}
  <svg class="gk-ico" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="8" stroke="currentColor"/>
  </svg>

{%- endcase -%}
