<script>
  (function () {
    var COMPANY_ID = {{ kl_company | json }};
    var LIST_ID = {{ kl_list | json }};

    var form = document.getElementById('vopt-form');
    var success = document.getElementById('vopt-success');
    var errorEl = document.getElementById('vopt-error');
    var submitBtn = document.getElementById('vopt-submit');
    var firstName = document.getElementById('vopt-firstname');

    function isValidEmail(value) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
    }

    function showSuccess() {
      if (form) form.setAttribute('hidden', 'hidden');
      if (success) success.removeAttribute('hidden');
    }

    function showError() {
      if (errorEl) errorEl.removeAttribute('hidden');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'SEND ME THE VAULT →';
      }
    }

    if (form) {
      form.addEventListener('submit', function (event) {
        event.preventDefault();
        if (errorEl) errorEl.setAttribute('hidden', 'hidden');

        var emailEl = document.getElementById('vopt-email');
        var lastEl = document.getElementById('vopt-lastname');
        var email = emailEl ? emailEl.value.trim() : '';

        if (!isValidEmail(email)) {
          showError();
          if (emailEl) emailEl.focus();
          return;
        }

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'SENDING…';
        }

        var payload = {
          data: {
            type: 'subscription',
            attributes: {
              profile: {
                data: {
                  type: 'profile',
                  attributes: {
                    email: email,
                    first_name: firstName ? firstName.value.trim() : '',
                    last_name: lastEl ? lastEl.value.trim() : ''
                  }
                }
              }
            },
            relationships: {
              list: { data: { type: 'list', id: LIST_ID } }
            }
          }
        };

        fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + encodeURIComponent(COMPANY_ID), {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            revision: '2024-10-15'
          },
          body: JSON.stringify(payload)
        })
          .then(function (response) {
            if (response.ok || response.status === 202) {
              showSuccess();
            } else {
              showError();
            }
          })
          .catch(showError);
      });
    }

    // Mid-page and final CTA buttons scroll to the form and focus the first name field.
    var scrollButtons = document.querySelectorAll('.vopt-scroll-btn');
    var formCard = document.getElementById('vopt-form-card');
    for (var i = 0; i < scrollButtons.length; i++) {
      scrollButtons[i].addEventListener('click', function () {
        if (formCard) {
          formCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        window.setTimeout(function () {
          if (firstName && !form.hasAttribute('hidden')) firstName.focus({ preventScroll: true });
        }, 550);
      });
    }
  })();
</script>

