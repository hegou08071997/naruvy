<header class="vopt-hero vopt-wrap--wide">
  <div class="vopt-hero-grid">
    <div class="vopt-hero-copy">
      {%- if section.settings.kicker != blank -%}
        <p class="vopt-kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <h1 class="vopt-h1">
        {{- section.settings.heading_line1 | escape -}}
        {%- if section.settings.heading_line2 != blank -%}
          <br><span class="vopt-accent-text">{{ section.settings.heading_line2 | escape }}</span>
        {%- endif -%}
      </h1>
      {%- if section.settings.value_line != blank -%}
        <p class="vopt-hero-value">{{ section.settings.value_line }}</p>
      {%- endif -%}
      {%- if section.settings.lead != blank -%}
        <p class="vopt-hero-lead">{{ section.settings.lead | escape }}</p>
      {%- endif -%}
      {%- if section.settings.pain != blank -%}
        <p class="vopt-hero-pain">{{ section.settings.pain | escape }}</p>
      {%- endif -%}
      <div class="vopt-hero-cta">
        {%- if section.settings.button_link != blank -%}
          <a href="{{ section.settings.button_link }}" class="vopt-btn vopt-btn--inline">{{ section.settings.button_label | escape }}</a>
        {%- else -%}
          <button type="button" class="vopt-btn vopt-btn--inline vopt-scroll-btn">{{ section.settings.button_label | escape }}</button>
        {%- endif -%}
        {%- if section.settings.microcopy != blank -%}
          <p class="vopt-hero-micro">{{ section.settings.microcopy | escape }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Vault preview: layered lesson tiles being unlocked {%- endcomment -%}
    <div class="vopt-hero-visual" aria-hidden="true">
      <span class="vopt-hero-glow"></span>
      <div class="vopt-vault">
        <div class="vopt-vault-tile vopt-vault-tile--back1">
          <div class="vopt-tile-thumb">
            <span class="vopt-tile-tag">FREE · 04</span>
            <span class="vopt-play vopt-play--sm"></span>
            <span class="vopt-wave"></span>
          </div>
          <div class="vopt-tile-meta">Outside Playing</div>
        </div>
        <div class="vopt-vault-tile vopt-vault-tile--back2">
          <div class="vopt-tile-thumb">
            <span class="vopt-tile-tag">FREE · 05</span>
            <span class="vopt-play vopt-play--sm"></span>
            <span class="vopt-wave"></span>
          </div>
          <div class="vopt-tile-meta">Tone &amp; Gear</div>
        </div>
        <div class="vopt-vault-tile vopt-vault-tile--front">
          <div class="vopt-tile-thumb">
            <span class="vopt-tile-tag">FREE · 01</span>
            <span class="vopt-play"></span>
            <span class="vopt-wave"></span>
          </div>
          <div class="vopt-tile-meta">Chicken Pickin&rsquo;</div>
        </div>
        <div class="vopt-pdf-chip">
          <i class="ti ti-file-description"></i>
          <span class="vopt-pdf-chip-label">Master PDF<small>12-page reference</small></span>
        </div>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Vault Hero",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "The Gristle Vault · Free Access"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Headline line 1",
      "default": "ACCESS THE"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Headline line 2 (accent color)",
      "default": "GRISTLE VAULT"
    },
    {
      "type": "text",
      "id": "value_line",
      "label": "Value line",
      "info": "Shown in display type below the headline. HTML allowed for accent spans.",
      "default": "8 Videos · 4+ Hours · 1 Master PDF · All Free"
    },
    {
      "type": "text",
      "id": "lead",
      "label": "Lead line",
      "default": "Stop digging through random clips. Get the actual stash."
    },
    {
      "type": "textarea",
      "id": "pain",
      "label": "Pain copy",
      "default": "Most players collect random licks, scattered YouTube clips, and half-finished lessons. The Vault gives you a clear stash of Greg's real lessons, clinics, and breakdowns in one place."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "UNLOCK THE FREE STASH →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link (optional)",
      "info": "Leave blank to scroll the visitor to the opt-in form and focus the first name field."
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy under button",
      "default": "Free. No credit card. Instant access."
    }
  ],
  "presets": [{ "name": "Vault Hero" }]
}
{% endschema %}
