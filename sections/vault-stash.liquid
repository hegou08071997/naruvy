{%- if section.settings.show_top_divider -%}
  <div class="vopt-divider"><hr></div>
{%- endif -%}

<section class="vopt-stash vopt-wrap--wide">
  {%- if section.settings.eyebrow != blank -%}
    <p class="vopt-eyebrow">{{ section.settings.eyebrow | escape }}</p>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 class="vopt-h2">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}
  {%- if section.settings.subhead != blank -%}
    <p class="vopt-section-sub">{{ section.settings.subhead | escape }}</p>
  {%- endif -%}

  <div class="vopt-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'card' -%}
        <article class="vopt-card-item" data-w="{{ block.settings.width | default: 'third' }}" {{ block.shopify_attributes }}>
          <div class="vopt-card-head">
            {%- if block.settings.free_label != blank -%}
              <span class="vopt-card-free">{{ block.settings.free_label | escape }}</span>
            {%- endif -%}
            <span class="vopt-card-rivet" aria-hidden="true"></span>
          </div>
          <div class="vopt-card-well">
            {% render 'vault-emblem', key: block.settings.emblem %}
            <span class="vopt-wave" aria-hidden="true"></span>
          </div>
          <div class="vopt-card-body">
            {%- if block.settings.title != blank -%}
              <h3 class="vopt-card-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="vopt-card-desc">{{ block.settings.description | escape }}</p>
            {%- endif -%}
          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.show_pdf -%}
    <div class="vopt-pdf">
      <span class="vopt-pdf-badge">{% render 'vault-emblem', key: 'pdf' %}</span>
      <div class="vopt-pdf-text">
        {%- if section.settings.pdf_kicker != blank -%}
          <p class="vopt-pdf-kicker">{{ section.settings.pdf_kicker | escape }}</p>
        {%- endif -%}
        {%- if section.settings.pdf_title != blank -%}
          <p class="vopt-pdf-title">{{ section.settings.pdf_title | escape }}</p>
        {%- endif -%}
        {%- if section.settings.pdf_desc != blank -%}
          <p class="vopt-pdf-desc">{{ section.settings.pdf_desc | escape }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Vault Stash",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show divider above section",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What is inside the vault"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE FULL STASH."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subhead",
      "default": "Eight complete sessions. Every one a real lesson. Not a teaser. Not a highlight reel."
    },
    {
      "type": "header",
      "content": "PDF callout"
    },
    {
      "type": "checkbox",
      "id": "show_pdf",
      "label": "Show PDF callout",
      "default": true
    },
    {
      "type": "text",
      "id": "pdf_kicker",
      "label": "PDF kicker",
      "default": "Vault file · PDF included"
    },
    {
      "type": "text",
      "id": "pdf_title",
      "label": "PDF title",
      "default": "The Gristle Vault Master Reference"
    },
    {
      "type": "textarea",
      "id": "pdf_desc",
      "label": "PDF description",
      "default": "A 12-page document covering every technique, chord voicing, gear spec, and principle from all 8 videos. Built to keep open while you watch."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Vault card",
      "settings": [
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "default": "third",
          "options": [
            { "value": "third", "label": "Third (1/3)" },
            { "value": "half", "label": "Half (1/2)" },
            { "value": "full", "label": "Full width" }
          ]
        },
        {
          "type": "select",
          "id": "emblem",
          "label": "Lesson emblem",
          "default": "pick",
          "options": [
            { "value": "pick", "label": "Guitar pick medallion" },
            { "value": "travis", "label": "Fingerpicking marks" },
            { "value": "chords", "label": "Fretboard chord dots" },
            { "value": "outside", "label": "Note breaking outside" },
            { "value": "tone", "label": "Amp knob" },
            { "value": "blues", "label": "String bend" },
            { "value": "song", "label": "Film strip waveform" },
            { "value": "clinic", "label": "Ribbon microphone" }
          ]
        },
        {
          "type": "text",
          "id": "free_label",
          "label": "Header label",
          "default": "FREE · 01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Card title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Card description."
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Vault Stash",
      "blocks": [
        { "type": "card", "settings": { "width": "third", "icon": "ti-guitar-pick", "free_label": "FREE · 01", "title": "Chicken Picking Masterclass", "description": "Thumb and finger foundation to full hybrid integration. The muted note, the pop, the banjo rolls, the Magic Sam lick. Everything." } },
        { "type": "card", "settings": { "width": "third", "icon": "ti-music", "free_label": "FREE · 02", "title": "Travis Picking Deep Dive", "description": "Learned with a flat pick. How to build the boom-chuck foundation without speeding up before you are ready." } },
        { "type": "card", "settings": { "width": "third", "icon": "ti-piano", "free_label": "FREE · 03", "title": "Chord Vocabulary", "description": "James Burton ninth chord bend, Robben Ford chord melody, Allan Holdsworth minor 11th, the Steely Dan sus chord." } },
        { "type": "card", "settings": { "width": "third", "icon": "ti-wave-sine", "free_label": "FREE · 04", "title": "Outside Playing", "description": "Pentatonic substitutions, chromatic approaches, diminished arpeggios, the tritone sub, and the Mahavishnu scale. Sound outside without sounding lost." } },
        { "type": "card", "settings": { "width": "third", "icon": "ti-adjustments", "free_label": "FREE · 05", "title": "Tone and Gear Rundown", "description": "The full live rig. Reverend guitars, Fishman Fluence pickups, Tone King Royalist, every pedal on the board with context for why each one gets used." } },
        { "type": "card", "settings": { "width": "third", "icon": "ti-microphone", "free_label": "FREE · 06", "title": "Blues Soloing Concepts", "description": "Playing over changes instead of camping on pentatonic. Jeff Beck whammy techniques, self-accompanied blues, the Allman Brothers approach to major and minor." } },
        { "type": "card", "settings": { "width": "half", "icon": "ti-file-music", "free_label": "FREE · 07", "title": "Song Breakdowns", "description": "Note-for-note construction of Tonus Diabolicus and Spank It. Where every idea came from, how it was mutated, and exactly how to play it." } },
        { "type": "card", "settings": { "width": "half", "icon": "ti-video", "free_label": "FREE · 08", "title": "Live Clinics and Q&A", "description": "Full workshop recordings. A gear walkthrough, a backstage interview, and a live Q&A with working musicians." } }
      ]
    }
  ]
}
{% endschema %}
