flex-direction:column;justify-content:center;\n    overflow:hidden;\n  }\n  .hero-bg{\n    position:absolute;inset:0;\n    display:flex;\n  }\n  .hero-bg .half{width:50%;height:100%;}\n  .half.hot{background:linear-gradient(135deg,#3a2a12 0%, #16211F 70%);}\n  .half.cold{background:linear-gradient(225deg,#122b30 0%, #16211F 70%);}\n  .seam{\n    position:absolute;top:0;bottom:0;left:50%;width:64px;\n    transform:translateX(-50%);\n    clip-path:polygon(\n      50% 0%, 62% 4%, 46% 9%, 58% 14%, 42% 19%, 60% 25%, 44% 31%,\n      56% 37%, 40% 43%, 58% 49%, 42% 55%, 60% 61%, 44% 67%,\n      56% 73%, 40% 79%, 58% 85%, 46% 91%, 54% 96%, 50% 100%,\n      50% 96%, 50% 4%\n    );\n    background:linear-gradient(180deg, var(--amber), var(--ice));\n    opacity:0.9;\n  }\n  .hero-content{\n    position:relative;z-index:2;\n    padding:120px 32px 80px;\n    max-width:1180px;margin:0 auto;\n    width:100%;\n    text-align:center;\n  }\n  .eyebrow{\n    display:inline-flex;align-items:center;gap:10px;\n    color:var(--cream-dim);margin-bottom:28px;\n  }\n  .eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--amber);}\n  .eyebrow .dot.b{background:var(--ice);}\n  .hero h1{\n    font-size:clamp(40px, 7vw, 84px);\n    max-width:900px;margin:0 auto 28px;\n  }\n  .hero h1 .hot-word{color:var(--amber);}\n  .hero h1 .cold-word{color:var(--ice);}\n  .hero p{\n    font-size:18px;color:var(--cream-dim);\n    max-width:520px;margin:0 auto 40px;\n  }\n  .hero-ctas{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}\n  .btn-primary{\n    background:var(--cream);color:var(--bg);\n    padding:16px 32px;font-weight:700;font-size:14px;\n    text-transform:uppercase;letter-spacing:0.04em;\n    border-radius:2px;transition:transform .2s;\n  }\n  .btn-primary:hover{transform:translateY(-2px);}\n  .btn-ghost{\n    border:1px solid var(--line);\n    padding:16px 32px;font-weight:700;font-size:14px;\n    text-transform:uppercase;letter-spacing:0.04em;\n    border-radius:2px;color:var(--cream-dim);\n    transition:border-color .2s,color .2s;\n  }\n  .btn-ghost:hover{border-color:var(--cream-dim);color:var(--cream);}\n\n  /* STATS BAR */\n  .stats{\n    border-top:1px solid var(--line);border-bottom:1px solid var(--line);\n    background:var(--bg-soft);\n  }\n  .stats .wrap{\n    display:grid;grid-template-columns:repeat(4,1fr);\n    padding:36px 32px;\n  }\n  .stat{text-align:center;border-right:1px solid var(--line);}\n  .stat:last-child{border-right:none;}\n  .stat .num{font-family:'IBM Plex Mono';font-size:28px;font-weight:500;color:var(--ice);}\n  .stat .lbl{font-size:12px;color:var(--cream-dim);text-transform:uppercase;letter-spacing:0.06em;margin-top:6px;}\n\n  /* SECTION GENERIC */\n  section{padding:120px 0;}\n  .section-head{max-width:640px;margin-bottom:64px;}\n  .section-head .mono{color:var(--ice);margin-bottom:16px;display:block;}\n  .section-head h2{font-size:clamp(28px,4vw,44px);}\n  .section-head p{color:var(--cream-dim);margin-top:20px;font-size:16px;}\n\n  /* PRODUCTS */\n  .products-grid{\n    display:grid;grid-template-columns:repeat(3,1fr);gap:1px;\n    background:var(--line);border:1px solid var(--line);\n  }\n  .product-card{\n    background:var(--bg);padding:40px 32px;\n    display:flex;flex-direction:column;gap:16px;\n    transition:background .25s;\n  }\n  .product-card:hover{background:var(--bg-soft);}\n  .product-card .tag{\n    display:inline-block;width:fit-content;\n    font-family:'IBM Plex Mono';font-size:11px;\n    text-transform:uppercase;letter-spacing:0.06em;\n    padding:4px 10px;border-radius:2px;\n  }\n  .tag.heat{background:rgba(232,163,61,0.15);color:var(--amber);}\n  .tag.cold{background:rgba(111,184,201,0.15);color:var(--ice);}\n  .product-card h3{font-size:19px;margin-top:8px;}\n  .product-card p{color:var(--cream-dim);font-size:14px;flex:1;}\n  .product-card .price{\n    font-family:'IBM Plex Mono';font-size:16px;color:var(--cream);\n    padding-top:16px;border-top:1px solid var(--line);\n    display:flex;justify-content:space-between;align-items:center;\n  }\n  .price a{font-size:12px;text-transform:uppercase;color:var(--ice);font-weight:600;}\n\n  /* CONTRAST METHOD */\n  .method{background:var(--bg-soft);}\n  .method-grid{\n    display:grid;grid-template-columns:1fr 1fr;gap:0;\n    border:1px solid var(--line);\n  }\n  .method-col{padding:56px 48px;}\n  .method-col.heat{border-right:1px solid var(--line);}\n  .method-col .mono{margin-bottom:20px;display:block;}\n  .method-col.heat .mono{color:var(--amber);}\n  .method-col.cold .mono{color:var(--ice);}\n  .method-col h3{font-size:26px;margin-bottom:16px;}\n  .method-col p{color:var(--cream-dim);font-size:15px;}\n  .method-list{margin-top:24px;display:flex;flex-direction:column;gap:12px;}\n  .method-list div{\n    font-size:14px;color:var(--cream-dim);\n    padding-left:16px;position:relative;\n  }\n  .method-list div::before{\n    content:'';position:absolute;left:0;top:7px;\n    width:6px;height:6px;border-radius:50%;\n  }\n  .heat .method-list div::before{background:var(--amber);}\n  .cold .method-list div::before{background:var(--ice);}\n\n  /* TESTIMONIAL */\n  .testimonial{text-align:center;}\n  .testimonial blockquote{\n    font-family:'Archivo Expanded';font-weight:600;\n    font-size:clamp(22px,3vw,32px);\n    max-width:780px;margin:0 auto 28px;\n    text-transform:none;line-height:1.3;\n  }\n  .testimonial cite{color:var(--cream-dim);font-style:normal;font-size:14px;}\n\n  /* CTA FOOTER */\n  .cta-final{\n    text-align:center;\n    background:linear-gradient(135deg, rgba(232,163,61,0.08), rgba(111,184,201,0.08));\n    border-top:1px solid var(--line);border-bottom:1px solid var(--line);\n  }\n  .cta-final h2{font-size:clamp(32px,5vw,56px);margin-bottom:24px;}\n  .cta-final p{color:var(--cream-dim);margin-bottom:40px;}\n\n  footer{padding:56px 0 40px;}\n  footer .wrap{\n    display:flex;justify-content:space-between;align-items:center;\n    flex-wrap:wrap;gap:20px;\n  }\n  footer .flinks{displ