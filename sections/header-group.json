ase;\n  }\n  .nav-cta:hover{transform:translateY(-1px);box-shadow:0 6px 24px rgba(232,64,31,0.3);}\n\n  /* HERO */\n  .hero{\n    position:relative;\n    padding:88px 0 100px;\n    overflow:hidden;\n  }\n  .hero .wrap{\n    display:grid;grid-template-columns:1.05fr 0.95fr;gap:48px;align-items:center;\n  }\n  .eyebrow{\n    display:inline-flex;align-items:center;gap:8px;\n    font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.12em;\n    color:var(--heat-400);text-transform:uppercase;margin-bottom:22px;\n  }\n  .eyebrow::before{content:'●';color:var(--ember-500);font-size:8px;}\n  h1{\n    font-size:clamp(42px,6vw,72px);\n    line-height:0.98;\n    margin-bottom:22px;\n    color:var(--ink-900);\n  }\n  h1 .accent{color:var(--ember-500);}\n  .hero p.sub{\n    font-size:18px;color:var(--ink-600);max-width:460px;margin-bottom:34px;line-height:1.6;\n  }\n  .hero-ctas{display:flex;align-items:center;gap:20px;flex-wrap:wrap;}\n  .btn-primary{\n    background:linear-gradient(135deg,var(--ember-500),var(--ember-600));\n    color:#fff;\n    padding:16px 30px;border-radius:10px;font-weight:700;font-size:16px;\n    box-shadow:0 8px 30px rgba(232,64,31,0.25);\n    transition:transform .15s ease;\n    display:inline-block;\n  }\n  .btn-primary:hover{transform:translateY(-2px);}\n  .price-readout{\n    font-family:'IBM Plex Mono',monospace;\n  }\n  .price-readout .old{color:var(--ink-400);text-decoration:line-through;font-size:14px;}\n  .price-readout .new{color:var(--ember-600);font-size:26px;font-weight:600;display:block;}\n  .trust-row{\n    margin-top:34px;display:flex;gap:28px;flex-wrap:wrap;\n    font-size:13px;color:var(--ink-400);font-family:'IBM Plex Mono',monospace;\n  }\n  .trust-row span{color:var(--heat-400);}\n\n  /* HERO VISUAL - signature thermal pulse */\n  .hero-visual{\n    position:relative;\n    display:flex;align-items:center;justify-content:center;\n    height:460px;\n  }\n  .aura{\n    position:absolute;width:420px;height:420px;border-radius:50%;\n    background:radial-gradient(circle, rgba(232,64,31,0.35) 0%, rgba(242,144,10,0.20) 35%, rgba(232,64,31,0) 70%);\n    filter:blur(6px);\n    animation:pulse 3.2s ease-in-out infinite;\n  }\n  @keyframes pulse{\n    0%,100%{transform:scale(0.9);opacity:0.7;}\n    50%{transform:scale(1.08);opacity:1;}\n  }\n  .device-card{\n    position:relative;z-index:2;\n    width:260px;height:340px;\n    background:linear-gradient(160deg,#FFFFFF,var(--card-alt));\n    border:1px solid var(--border);\n    border-radius:24px;\n    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;\n    box-shadow:0 30px 60px rgba(27,29,34,0.12);\n  }\n  .device-icon{\n    width:88px;height:88px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, var(--heat-400), var(--ember-600));\n    box-shadow:0 0 40px rgba(232,64,31,0.35);\n  }\n  .device-readout{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--ink-400);text-align:center;line-height:1.8;}\n  .device-readout b{color:var(--ember-600);}\n\n  @media(max-width:860px){\n    .hero .wrap{grid-template-columns:1fr;}\n    .hero-visual{height:320px;order:-1;}\n    .device-card{width:220px;height:280px;}\n    .aura{width:320px;height:320px;}\n  }\n\n  /* FEATURE STRIP */\n  .features{\n    border-top:1px solid var(--border);\n    border-bottom:1px solid var(--border);\n    background:var(--card);\n  }\n  .features .wrap{\n    display:grid;grid-template-columns:repeat(3,1fr);\n  }\n  .feature{\n    padding:36px 28px;border-right:1px solid var(--border);\n  }\n  .feature:last-child{border-right:none;}\n  .feature .stat{font-family:'IBM Plex Mono',monospace;font-size:34px;color:var(--ember-500);font-weight:600;}\n  .feature .label{font-size:14px;color:var(--ink-600);margin-top:6px;}\n  @media(max-width:700px){\n    .features .wrap{grid-template-columns:1fr;}\n    .feature{border-right:none;border-bottom:1px solid var(--border);}\n  }\n\n  /* SECTION HEADS */\n  section{padding:100px 0;}\n  .section-head{max-width:560px;margin-bottom:56px;}\n  .section-head .kicker{\n    font-family:'IBM Plex Mono',monospace;color:var(--heat-400);font-size:13px;\n    letter-spacing:0.1em;text-transform:uppercase;margin-bottom:14px;display:block;\n  }\n  .section-head h2{font-size:clamp(30px,4vw,44px);line-height:1.05;color:var(--ink-900);}\n\n  /* HOW IT WORKS */\n  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;}\n  .step{\n    background:var(--card);border:1px solid var(--border);border-radius:18px;\n    padding:32px 26px;position:relative;\n    box-shadow:0 2px 14px rgba(27,29,34,0.04);\n  }\n  .step .num{\n    font-family:'Anton',sans-serif;font-size:56px;color:var(--card-alt);\n    position:absolute;top:16px;right:22px;line-height:1;\n  }\n  .step h3{font-size:19px;margin:18px 0 10px;position:relative;z-index:1;color:var(--ink-900);}\n  .step p{color:var(--ink-600);font-size:14.5px;line-height:1.6;position:relative;z-index:1;}\n  @media(max-width:800px){.steps{grid-template-columns:1fr;}}\n\n  /* AUDIENCE */\n  .audience-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}\n  .aud-card{\n    background:var(--card);border:1px solid var(--border);border-radius:16px;\n    padding:26px 22px;transition:border-color .15s ease, box-shadow .15s ease;\n    box-shadow:0 2px 14px rgba(27,29,34,0.04);\n  }\n  .aud-card:hover{border-color:var(--ember-500);box-shadow:0 8px 24px rgba(232,64,31,0.12);}\n  .aud-card .emoji{font-size:28px;margin-bottom:14px;}\n  .aud-card h4{font-size:16px;margin-bottom:8px;color:var(--ink-900);}\n  .aud-card p{font-size:13.5px;color:var(--ink-600);line-height:1.55;}\n  @media(max-width:900px){.audience-grid{grid-template-columns:repeat(2,1fr);}}\n  @media(max-width:520px){.audience-grid{grid-template-columns:1fr;}}\n\n  /* THERMAL TOGGLE - signature interactive moment */\n  .thermal-demo{\n    background:var(--card);border:1px solid var(--border);border-radius:24px;\n    padding:48px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;\n    box-shadow:0 2px 14px rgba(27,29,34,0.04);\n  }\n  .thermal-visual{\n    position:relative;height:280px;border-radius:18px;overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n    transition:background 0.8s ease;\n    background:radial-gradient(circle at 50% 45%, #6E94AE 0%, #33455A 60%);\n  }\n  .thermal-visual.warm{\n    background:radial-gradient(circle at 50% 45%, var(--heat-400) 0%, var(--ember-600) 55%, #4A2312 85%);\n  }\n  .thermal-visual .figure{width:70px;height:180px;border-radius:35px;background:rgba(255,255,255,0.92);opacity:0.9;transition:transform .8s ease;}\n  .thermal-visual.warm .figure{transform:scale(1.03);}\n  .thermal-label{\n    position:absolute;bottom:16px;left:16px;font-family:'IBM Plex Mono',monospace;\n    font-size:12px;color:#fff;background:rgba(27,29,34,0.55);padding:6px 12px;border-radius:100px;\n  }\n  .toggle-row{display:flex;gap:12px;margin-top:20px;}\n  .toggle-btn{\n    padding:10px 20px;border-radius:100px;border:1px solid var(--border);\n    font-family:'IBM Plex Mono',monospace;font-size:13px;cursor:pointer;\n    background:var(--card);color:var(--ink-600);\n  }\n  .toggle-btn.active{background:var(--ember-500);color:#fff;border-color:var(--ember-500);font-weight:600;}\n  .thermal-copy h3{font-size:24px;margin-bottom:14px;color:var(--ink-900);}\n  .thermal-copy p{color:var(--ink-600);line-height:1.65;font-size:15px;}\n  @media(max-width:800px){.thermal-demo{grid-template-columns:1fr;padding:30px;}}\n\n  /* TESTIMONIALS */\n  .test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}\n  .test-card{\n    background:var(--card);border:1px solid var(--border);border-radius:18px;\n    padding:24px;\n    box-shadow:0 2px 14px rgba(27,29,34,0.04);\n  }\n  .test-video{\n    width:100%;aspect-ratio:9/13;border-radius:12px;margin-bottom:16px;\n    background:linear-gradient(160deg,var(--card-alt),#E3E6EB);\n    display:flex;align-items:center;justify-content:center;position:relative;\n  }\n  .test-video::after{\n    content:'▶';color:var(--ember-500);font-size:22px;\n  }\n  .test-card p{font-size:14px;color:var(--ink-600);line-height:1.6;margin-bottom:10px;}\n  .test-card .who{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--heat-400);}\n  @media(max-width:800px){.test-grid{grid-template-columns:1fr;}}\n\n  /* FINAL CTA */\n  .final-cta{\n    background:linear-gradient(160deg,var(--card),var(--bg));\n    border-top:1px solid var(--border);\n    text-align:center;\n  }\n  .final-cta h2{font-size:clamp(32px,5vw,52px);margin-bottom:18px;color:var(--ink-900);}\n  .final-cta p{color:var(--ink-600);margin-bottom:36px;font-size:16px;}\n  .guarantee-row{\n    margin-top:44px;display:flex;justify-content:center;gap:40px;flex-wrap:wrap;\n    font-size:13px;color:var(--ink-400);font-family:'IBM Plex Mono',monospace;\n  }\n\n  footer{\n    border-top:1px solid var(--border);padding:32px 0;text-align:center;\n    color:var(--ink-400);font-size:13px;\n  }\n</style>\n</head>\n<body>\n\n<nav>\n  <div class=\"wrap\">\n    <div class=\"logo\">\n      <div class=\"logo-dot\"></div>\n      <span>RECOVR</span>\n    </div>\n    <a href=\"#comprar\" class=\"nav-cta\">Comprar ahora</a>\n  </div>\n</nav>\n\n<section class=\"hero\">\n  <div class=\"wrap\">\n    <div>\n      <div class=\"eyebrow\">Calor · Percusión · Luz roja 660nm</div>\n      <h1>RECUPERA MÁS RÁPIDO.<br>ENTRENA <span class=\"accent\">MÁS FUERTE.</span></h1>\n      <p class=\"sub\">El único masajeador que combina percusión profunda, calor terapéutico y luz roja en un solo dispositivo. Diseñado para corredores, atletas y cualquiera que viva con el cuerpo cansado.</p>\n      <div class=\"hero-ctas\">\n        <a href=\"#comprar\" class=\"btn-primary\">Quiero el mío →</a>\n        <div class=\"price-readout\">\n          <span class=\"old\">89,00 €</span>\n          <span class=\"new\">49,00 €</span>\n        </div>\n      </div>\n      <div class=\"trust-row\">\n        <div>✓ Envío <span>2–4 días</span></div>\n        <div>✓ Garantía <span>30 días</span></div>\n        <div>✓ +2.400 <span>reseñas</span></div>\n      </div>\n    </div>\n    <div class=\"hero-visual\">\n      <div class=\"aura\"></div>\n      <div class=\"device-card\">\n        <div class=\"device-icon\"></div>\n        <div class=\"device-readout\">\n          TEMP <b>45°C</b> · LIGHT <b>660nm</b><br>\n          MODO <b>RECOVERY</b>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"features\">\n  <div class=\"wrap\">\n    <div class=\"feature\">\n      <div class=\"stat\">3200</div>\n      <div class=\"label\">Percusiones por minuto — llega al músculo profundo</div>\n    </div>\n    <div class=\"feature\">\n      <div class=\"stat\">45°C</div>\n      <div class=\"label\">Calor constante — relaja la fibra antes del masaje</div>\n    </div>\n    <div class=\"feature\">\n      <div class=\"stat\">660nm</div>\n      <div class=\"label\">Luz roja terapéutica — acelera la recuperación celular</div>\n    </div>\n  </div>\n</section>\n\n<section>\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <span class=\"kicker\">Cómo funciona</span>\n      <h2>Tres tecnologías. Una sola sesión de 10 minutos.</h2>\n    </div>\n    <div class=\"steps\">\n      <div class=\"step\">\n        <div class=\"num\">01</div>\n        <h3>Calienta el tejido</h3>\n        <p>El calor previo dilata los vasos sanguíneos y prepara el músculo, haciendo que el masaje sea más efectivo desde el primer segundo.</p>\n      </div>\n      <div class=\"step\">\n        <div class=\"num\">02</div>\n        <h3>Percute a fondo</h3>\n        <p>La percusión rompe la tensión acumulada y mejora el flujo sanguíneo en la zona, igual que un masaje deportivo profesional.</p>\n      </div>\n      <div class=\"step\">\n        <div class=\"num\">03</div>\n        <h3>Repara con luz roja</h3>\n        <p>La luz a 660nm estimula la recuperación celular, reduciendo la inflamación y el dolor muscular de las horas siguientes.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section style=\"background:var(--card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <span class=\"kicker\">Para quién es</span>\n      <h2>Si tu cuerpo trabaja duro, esto es para ti.</h2>\n    </div>\n    <div class=\"audience-grid\">\n      <div class=\"aud-card\">\n        <div class=\"emoji\">🏃</div>\n        <h4>Runners</h4>\n        <p>Recupera piernas cansadas después de cada tirada larga.</p>\n      </div>\n      <div class=\"aud-card\">\n        <div class=\"emoji\">💻</div>\n        <h4>Trabajo remoto</h4>\n        <p>Alivia cuello y espalda tras horas frente al ordenador.</p>\n      </div>\n      <div class=\"aud-card\">\n        <div class=\"emoji\">🏋️</div>\n        <h4>CrossFit</h4>\n        <p>Reduce las agujetas y vuelve al box más rápido.</p>\n      </div>\n      <div class=\"aud-card\">\n        <div class=\"emoji\">🩺</div>\n        <h4>Fisioterapia</h4>\n        <p>Complementa tu rutina de rehabilitación en casa.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section>\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <span class=\"kicker\">Antes / Después</span>\n      <h2>De músculo tenso a músculo tratado.</h2>\n    </div>\n    <div class=\"thermal-demo\">\n      <div>\n        <div class=\"thermal-visual\" id=\"thermalVisual\">\n          <div class=\"figure\"></div>\n          <div class=\"thermal-label\" id=\"thermalLabel\">Sin tratar — tensión acumulada</div>\n        </div>\n        <div class=\"toggle-row\">\n          <button class=\"toggle-btn active\" id=\"btnCold\" onclick=\"setThermal(false)\">Antes</button>\n          <button class=\"toggle-btn\" id=\"btnWarm\" onclick=\"setThermal(true)\">Después</button>\n        </div>\n      </div>\n      <div class=\"thermal-copy\">\n        <h3>Así se siente la diferencia.</h3>\n        <p>El calor y la luz roja no son un efecto estético: aumentan la circulación local y ayudan a que el músculo pase de un estado de tensión a uno de recuperación activa en cuestión de minutos.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section style=\"background:var(--card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <span class=\"kicker\">Lo que dicen</span>\n      <h2>+2.400 personas ya recuperan mejor.</h2>\n    </div>\n    <div class=\"test-grid\">\n      <div class=\"test-card\">\n        <div class=\"test-video\"></div>\n        <p>\"Lo uso después de cada carrera. La función de calor marca la diferencia frente a otros que he probado.\"</p>\n        <div class=\"who\">— Runner, Madrid</div>\n      </div>\n      <div class=\"test-card\">\n        <div class=\"test-video\"></div>\n        <p>\"Trabajo 9 horas sentada y esto se ha vuelto parte de mi rutina de noche. El cuello lo nota.\"</p>\n        <div class=\"who\">— Oficina remota, Valencia</div>\n      </div>\n      <div class=\"test-card\">\n        <div class=\"test-video\"></div>\n        <p>\"Se lo recomiendo a mis pacientes como complemento. La luz roja es un plus que no tienen otros modelos.\"</p>\n        <div class=\"who\">— Fisioterapeuta</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"final-cta\" id=\"comprar\">\n  <div class=\"wrap\">\n    <h2>Tu cuerpo se recupera<br>mientras tú sigues.</h2>\n    <p>Oferta de lanzamiento — stock limitado.</p>\n    <div class=\"price-readout\" style=\"margin-bottom:26px;\">\n      <span class=\"old\">89,00 €</span>\n      <span class=\"new\">49,00 €</span>\n    </div>\n    <a href=\"#\" class=\"btn-primary\">Comprar ahora →</a>\n    <div class=\"guarantee-row\">\n      <div>✓ Pago seguro</div>\n      <div>✓ Devolución 30 días</div>\n      <div>✓ Envío 2–4 días</div>\n    </div>\n  </div>\n</section>\n\n<footer>\n  RECOVR © 2026 — Recuperación muscular con calor, percusión y luz roja.\n</footer>\n\n<script>\nfunction setThermal(warm){\n  const vis = document.getElementById('thermalVisual');\n  const label = document.getElementById('thermalLabel');\n  const btnCold = document.getElementById('btnCold');\n  const btnWarm = document.getElementById('btnWarm');\n  if(warm){\n    vis.classList.add('warm');\n    label.textContent = 'Tratado — calor + luz roja activados';\n    btnWarm.classList.add('active');\n    btnCold.classList.remove('active');\n  } else {\n    vis.classList.remove('warm');\n    label.textContent = 'Sin tratar — tensión acumulada';\n    btnCold.classList.add('active');\n    btnWarm.classList.remove('active');\n  }\n}\n</script>\n\n</body>\n</html>",
