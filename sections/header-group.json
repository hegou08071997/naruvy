    "custom_liquid_JjQzVh": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>THERAPULSE® — Percusión, Calor y Luz Roja para tu Recuperación Muscular</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg:#FAF8F4;\n    --bg-alt:#F1EDE5;\n    --surface:#FFFFFF;\n    --surface-2:#F1EDE5;\n    --border:#E4DFD3;\n    --text:#20211F;\n    --text-muted:#66655D;\n    --text-faint:#9C978A;\n    --ember:#FF5A36;\n    --ember-dim:#FFD9CC;\n    --glow:#D62A4B;\n    --teal:#0E8E82;\n    --radius:14px;\n    --display: 'Oswald', sans-serif;\n    --body: 'Inter', sans-serif;\n    --mono: 'IBM Plex Mono', monospace;\n  }\n  *{box-sizing:border-box; margin:0; padding:0;}\n  html{scroll-behavior:smooth;}\n  body{\n    background:var(--bg);\n    color:var(--text);\n    font-family:var(--body);\n    line-height:1.55;\n    -webkit-font-smoothing:antialiased;\n    overflow-x:hidden;\n  }\n  a{color:inherit; text-decoration:none;}\n  img,svg{display:block; max-width:100%;}\n  .wrap{max-width:1180px; margin:0 auto; padding:0 24px;}\n  .eyebrow{\n    font-family:var(--mono);\n    font-size:12px;\n    letter-spacing:.12em;\n    text-transform:uppercase;\n    color:var(--teal);\n    display:flex; align-items:center; gap:8px;\n  }\n  .eyebrow::before{content:''; width:16px; height:1px; background:var(--teal);}\n  h1,h2,h3{font-family:var(--display); font-weight:600; letter-spacing:.01em; text-transform:uppercase;}\n  h2{font-size:clamp(28px,4vw,42px); line-height:1.1; margin-bottom:14px;}\n  h3{font-size:19px; margin-bottom:8px;}\n  p.lead{color:var(--text-muted); font-size:17px; max-width:560px;}\n  .btn{\n    display:inline-flex; align-items:center; justify-content:center; gap:10px;\n    font-family:var(--body); font-weight:700; font-size:15px;\n    padding:16px 30px; border-radius:999px; border:none; cursor:pointer;\n    transition:transform .15s ease, box-shadow .15s ease, background .15s ease;\n  }\n  .btn-primary{\n    background:linear-gradient(95deg, var(--ember), var(--glow));\n    color:#FFFFFF;\n    box-shadow:0 10px 26px -8px rgba(255,90,54,.4);\n  }\n  .btn-primary:hover{transform:translateY(-2px); box-shadow:0 16px 30px -8px rgba(255,90,54,.5);}\n  .btn-ghost{\n    background:transparent; color:var(--text); border:1px solid var(--border);\n  }\n  .btn-ghost:hover{border-color:var(--teal); color:var(--teal);}\n  .btn-small{padding:10px 18px; font-size:13px;}\n\n  /* NAV */\n  header{\n    position:sticky; top:0; z-index:100;\n    background:rgba(250,248,244,.85); backdrop-filter:blur(10px);\n    border-bottom:1px solid var(--border);\n  }\n  nav{display:flex; align-items:center; justify-content:space-between; padding:16px 24px;}\n  .logo{font-family:var(--display); font-weight:700; font-size:20px; letter-spacing:.04em; display:flex; align-items:center; gap:8px;}\n  .logo span{color:var(--ember);}\n  .nav-links{display:flex; gap:32px; font-size:14px; color:var(--text-muted);}\n  .nav-links a:hover{color:var(--text);}\n  .nav-cta{display:flex; align-items:center; gap:16px;}\n  .burger{display:none; background:none; border:none; color:var(--text); font-size:24px; cursor:pointer;}\n  @media (max-width:860px){\n    .nav-links{display:none;}\n    .burger{display:block;}\n  }\n\n  /* HERO */\n  .hero{\n    position:relative; padding:88px 0 70px;\n    background:\n      radial-gradient(ellipse 700px 400px at 78% 20%, rgba(230,57,80,.10), transparent 60%),\n      radial-gradient(ellipse 600px 500px at 10% 90%, rgba(255,90,54,.08), transparent 60%);\n    border-bottom:1px solid var(--border);\n    overflow:hidden;\n  }\n  .hero-grid{display:grid; grid-template-columns:1.05fr .95fr; gap:56px; align-items:center;}\n  @media (max-width:900px){ .hero-grid{grid-template-columns:1fr;} }\n  .hero h1{font-size:clamp(36px,5.2vw,58px); line-height:1.02; margin:18px 0 20px;}\n  .hero h1 .hl{color:var(--ember);}\n  .badges-row{display:flex; flex-wrap:wrap; gap:10px; margin-top:26px;}\n  .badge{\n    font-family:var(--mono); font-size:11.5px; color:var(--text-muted);\n    border:1px solid var(--border); padding:7px 12px; border-radius:999px;\n    display:flex; align-items:center; gap:6px;\n  }\n  .badge svg{width:13px; height:13px; stroke:var(--teal);}\n  .hero-cta-row{display:flex; align-items:center; gap:18px; margin-top:30px; flex-wrap:wrap;}\n  .price-tag{font-family:var(--mono); font-size:13px; color:var(--text-faint);}\n  .price-tag b{color:var(--text); font-size:22px; font-family:var(--body);}\n\n  /* Signature visual: pulsing muscle silhouette */\n  .device-stage{\n    position:relative; aspect-ratio:1/1.05; max-width:440px; margin:0 auto;\n    background:radial-gradient(circle at 50% 45%, rgba(230,57,80,.10), transparent 65%);\n    border-radius:24px;\n  }\n  .zone{ animation: pulseZone 2.8s ease-in-out infinite; transform-origin:center; }\n  .zone.z2{ animation-delay:.5s; }\n  .zone.z3{ animation-delay:1s; }\n  .zone.z4{ animation-delay:1.5s; }\n  @keyframes pulseZone{\n    0%,100%{ opacity:.35; }\n    50%{ opacity:.95; }\n  }\n  .ring{ animation: ringPulse 2.8s ease-out infinite; transform-origin:center; }\n  @keyframes ringPulse{\n    0%{ opacity:.6; r:10;}\n    100%{ opacity:0; r:34;}\n  }\n  @media (prefers-reduced-motion: reduce){\n    .zone, .ring{ animation:none !important; opacity:.75 !important; }\n  }\n\n  /* SECTION generic */\n  section{padding:86px 0;}\n  .section-head{max-width:640px; margin-bottom:52px;}\n  .section-head.center{margin-left:auto; margin-right:auto; text-align:center;}\n\n  /* Problem */\n  .pain-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:22px;}\n  @media (max-width:800px){ .pain-grid{grid-template-columns:1fr;} }\n  .pain-card{\n    background:var(--surface); border:1px solid var(--border); border-radius:var(--radius);\n    padding:26px;\n  }\n  .pain-card svg{width:26px; height:26px; stroke:var(--ember); margin-bottom:14px;}\n  .pain-card p{color:var(--text-muted); font-size:14.5px;}\n\n  /* Pillars (tech stack, ordered = real sequence) */\n  .pillars{ background:var(--bg-alt); border-top:1px solid var(--border); border-bottom:1px solid var(--border); }\n  .pillar-row{display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--border); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden;}\n  @media (max-width:800px){ .pillar-row{grid-template-columns:1fr;} }\n  .pillar{ background:var(--surface); padding:34px 28px; position:relative;}\n  .pillar .step-no{ font-family:var(--mono); font-size:12px; color:var(--text-faint); letter-spacing:.1em;}\n  .pillar .icon-wrap{\n    width:52px; height:52px; border-radius:12px; display:flex; align-items:center; justify-content:center;\n    margin:14px 0 18px; background:var(--surface-2); border:1px solid var(--border);\n  }\n  .pillar .icon-wrap svg{width:24px; height:24px;}\n  .pillar:nth-child(1) .icon-wrap svg{stroke:var(--teal);}\n  .pillar:nth-child(2) .icon-wrap svg{stroke:var(--ember);}\n  .pillar:nth-child(3) .icon-wrap svg{stroke:var(--glow);}\n  .pillar p{color:var(--text-muted); font-size:14.5px;}\n\n  /* Comparison table */\n  .compare-wrap{ overflow-x:auto; border:1px solid var(--border); border-radius:var(--radius); }\n  table{ width:100%; border-collapse:collapse; min-width:560px; }\n  th,td{ padding:16px 20px; text-align:left; font-size:14px; border-bottom:1px solid var(--border); }\n  th{ font-family:var(--mono); font-size:11.5px; text-transform:uppercase; letter-spacing:.08em; color:var(--text-faint); background:var(--surface);}\n  td.check{ color:var(--teal); font-weight:700; }\n  td.cross{ color:var(--text-faint); }\n  tr:last-child td{ border-bottom:none; }\n  tbody tr:nth-child(odd){ background:var(--surface); }\n  tbody tr:nth-child(even){ background:var(--bg-alt); }\n  .col-brand{ color:var(--ember); font-weight:700; }\n\n  /* Steps to use */\n  .use-steps{ display:grid; grid-template-columns:repeat(3,1fr); gap:22px; counter-reset:step; }\n  @media (max-width:800px){ .use-steps{grid-template-columns:1fr;} }\n  .use-step{ position:relative; padding-left:0; }\n  .use-step .num{\n    font-family:var(--display); font-size:44px; color:var(--bg); -webkit-text-stroke:1.5px var(--border);\n    line-height:1; margin-bottom:6px;\n  }\n\n  /* Testimonials */\n  .testi-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:18px; }\n  @media (max-width:960px){ .testi-grid{grid-template-columns:repeat(2,1fr);} }\n  @media (max-width:600px){ .testi-grid{grid-template-columns:1fr;} }\n  .testi-card{ background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:22px; display:flex; flex-direction:column; gap:14px;}\n  .stars{ color:var(--ember); font-size:13px; letter-spacing:2px;}\n  .testi-card p{ font-size:14px; color:var(--text-muted); flex:1;}\n  .testi-who{ display:flex; align-items:center; gap:10px; }\n  .avatar{ width:34px; height:34px; border-radius:50%; background:var(--surface-2); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; font-family:var(--display); font-size:13px; color:var(--teal);}\n  .testi-who .name{ font-size:13px; font-weight:600; }\n  .testi-who .role{ font-size:11.5px; color:var(--text-faint); font-family:var(--mono);}\n\n  /* Trust / guarantee */\n  .trust-band{ background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:44px; display:grid; grid-template-columns:1fr auto; gap:36px; align-items:center; }\n  @media (max-width:800px){ .trust-band{grid-template-columns:1fr; text-align:center;} }\n  .trust-icons{ display:flex; gap:34px; flex-wrap:wrap; justify-content:center;}\n  .trust-icon{ display:flex; flex-direction:column; align-items:center; gap:8px; width:96px;}\n  .trust-icon svg{width:28px; height:28px; stroke:var(--teal);}\n  .trust-icon span{ font-size:11.5px; color:var(--text-muted); text-align:center; }\n\n  /* FAQ */\n  .faq-item{ border-bottom:1px solid var(--border); }\n  .faq-q{ width:100%; display:flex; justify-content:space-between; align-items:center; background:none; border:none; color:var(--text); font-family:var(--body); font-size:16px; font-weight:600; padding:22px 0; cursor:pointer; text-align:left;}\n  .faq-q .plus{ font-family:var(--mono); color:var(--ember); font-size:20px; transition:transform .2s ease; flex:none; margin-left:16px;}\n  .faq-item.open .faq-q .plus{ transform:rotate(45deg); }\n  .faq-a{ max-height:0; overflow:hidden; transition:max-height .25s ease; }\n  .faq-a p{ color:var(--text-muted); font-size:14.5px; padding-bottom:22px; max-width:640px;}\n  .faq-item.open .faq-a{ max-height:220px; }\n\n  /* Final CTA */\n  .final-cta{\n    text-align:center; border-radius:24px; padding:70px 40px;\n    background:linear-gradient(160deg, var(--surface), var(--bg-alt));\n    border:1px solid var(--border);\n    position:relative; overflow:hidden;\n  }\n  .final-cta::before{\n    content:''; position:absolute; inset:0;\n    background:radial-gradient(ellipse 500px 260px at 50% 0%, rgba(230,57,80,.14), transparent 70%);\n  }\n  .final-cta > *{ position:relative; }\n  .final-cta h2{ margin-bottom:10px; }\n  .final-cta p.lead{ margin:0 auto 30px; }\n\n  footer{ border-top:1px solid var(--border); padding:44px 0 30px; }\n  .footer-grid{ display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:24px; }\n  .footer-links{ display:flex; gap:26px; font-size:13px; color:var(--text-muted); flex-wrap:wrap;}\n  .footer-note{ font-size:12px; color:var(--text-faint); margin-top:24px; max-width:720px; }\n\n  ::selection{ background:var(--ember); color:#FFFFFF; }\n</style>\n</head>\n<body>\n\n<header>\n  <nav class=\"wrap\">\n    <div class=\"logo\">THERA<span>PULSE</span>®</div>\n    <div class=\"nav-links\">\n      <a href=\"#tecnologia\">Tecnología</a>\n      <a href=\"#comparativa\">Comparativa</a>\n      <a href=\"#opiniones\">Opiniones</a>\n      <a href=\"#garantia\">Garantía</a>\n      <a href=\"#faq\">Preguntas</a>\n    </div>\n    <div class=\"nav-cta\">\n      <a href=\"#comprar\" class=\"btn btn-primary btn-small\">Comprar ahora</a>\n      <button class=\"burger\">☰</button>\n    </div>\n  </nav>\n</header>\n\n<section class=\"hero\">\n  <div class=\"wrap hero-grid\">\n    <div>\n      <div class=\"eyebrow\">Recuperación muscular · 3 tecnologías en 1</div>\n      <h1>Tu cuerpo se recupera <span class=\"hl\">mientras tú descansas.</span></h1>\n      <p class=\"lead\">Percusión profunda, calor terapéutico y luz roja infrarroja en un único dispositivo. Diseñado para corredores, deportistas de fuerza y cualquiera que pase el día sentado con la espalda en tensión.</p>\n\n      <div class=\"hero-cta-row\">\n        <a href=\"#comprar\" class=\"btn btn-primary\">Consigue el tuyo — 49€</a>\n        <a href=\"#tecnologia\" class=\"btn btn-ghost\">Cómo funciona</a>\n      </div>\n\n      <div class=\"badges-row\">\n        <span class=\"badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\"><path d=\"M20 6 9 17l-5-5\"/></svg>Envío en 3–6 días</span>\n        <span class=\"badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\"><path d=\"M20 6 9 17l-5-5\"/></svg>Garantía de 30 días</span>\n        <span class=\"badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\"><path d=\"M20 6 9 17l-5-5\"/></svg>Pago 100% seguro</span>\n      </div>\n    </div>\n\n    <div class=\"device-stage\">\n      <svg viewBox=\"0 0 300 320\" width=\"100%\">\n        <!-- simplified back/shoulders silhouette -->\n        <path d=\"M150 20c-30 0-46 22-46 46 0 18 8 30 8 30-30 10-50 34-56 70l-10 90c-2 14 8 26 22 26h164c14 0 24-12 22-26l-10-90c-6-36-26-60-56-70 0 0 8-12 8-30 0-24-16-46-46-46z\"\n          fill=\"#F1EDE5\" stroke=\"#E4DFD3\" stroke-width=\"1.5\"/>\n        <!-- glow zones -->\n        <circle class=\"zone z1\" cx=\"120\" cy=\"160\" r=\"26\" fill=\"#FF5A36\" opacity=\".4\" filter=\"url(#blur)\"/>\n        <circle class=\"zone z2\" cx=\"180\" cy=\"160\" r=\"26\" fill=\"#E63950\" opacity=\".4\" filter=\"url(#blur)\"/>\n        <circle class=\"zone z3\" cx=\"150\" cy=\"220\" r=\"30\" fill=\"#FF5A36\" opacity=\".35\" filter=\"url(#blur)\"/>\n        <circle class=\"zone z4\" cx=\"150\" cy=\"100\" r=\"20\" fill=\"#2DD4BF\" opacity=\".3\" filter=\"url(#blur)\"/>\n        <!-- pulse rings -->\n        <circle class=\"ring\" cx=\"120\" cy=\"160\" r=\"10\" fill=\"none\" stroke=\"#FF5A36\" stroke-width=\"2\"/>\n        <circle class=\"ring\" cx=\"180\" cy=\"160\" r=\"10\" fill=\"none\" stroke=\"#E63950\" stroke-width=\"2\" style=\"animation-delay:.7s\"/>\n        <circle class=\"ring\" cx=\"150\" cy=\"220\" r=\"10\" fill=\"none\" stroke=\"#FF5A36\" stroke-width=\"2\" style=\"animation-delay:1.4s\"/>\n        <defs>\n          <filter id=\"blur\"><feGaussianBlur stdDeviation=\"10\"/></filter>\n        </defs>\n      </svg>\n    </div>\n  </div>\n</section>\n\n<section id=\"problema\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <div class=\"eyebrow\">El problema</div>\n      <h2>¿Te reconoces en esto?</h2>\n    </div>\n    <div class=\"pain-grid\">\n      <div class=\"pain-card\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><path d=\"M12 2v6M12 16v6M4.9 4.9l4.2 4.2M14.9 14.9l4.2 4.2M2 12h6M16 12h6M4.9 19.1l4.2-4.2M14.9 9.1l4.2-4.2\"/></svg>\n        <h3>Agujetas que no se van</h3>\n        <p>Entrenas duro, pero la rigidez muscular te dura días y frena tu próxima sesión.</p>\n      </div>\n      <div class=\"pain-card\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"2\"/><path d=\"M9 9h6v6H9z\"/></svg>\n        <h3>Horas sentado, espalda en tensión</h3>\n        <p>El trabajo de oficina deja los hombros y la zona lumbar cargados al final del día.</p>\n      </div>\n      <div class=\"pain-card\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><path d=\"M12 22s8-4.5 8-11.8V5l-8-3-8 3v5.2C4 17.5 12 22 12 22z\"/></svg>\n        <h3>Ir al fisio cada semana no es sostenible</h3>\n        <p>Las sesiones ayudan, pero cuestan tiempo y dinero que no siempre tienes disponibles.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"pillars\" id=\"tecnologia\">\n  <div class=\"wrap\" style=\"padding:86px 0;\">\n    <div class=\"section-head\">\n      <div class=\"eyebrow\">La solución</div>\n      <h2>Tres terapias, una misma sesión</h2>\n      <p class=\"lead\">Cada tecnología prepara el músculo para la siguiente. Así es como actúan, en orden.</p>\n    </div>\n    <div class=\"pillar-row\">\n      <div class=\"pillar\">\n        <div class=\"step-no\">01 · CALOR</div>\n        <div class=\"icon-wrap\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><path d=\"M12 2c1 3-2 4-2 7a4 4 0 108 0c0-1-1-2-1-2 1 2 3 3 3 6a6 6 0 11-12 0c0-4 3-5 4-11z\"/></svg></div>\n        <h3>Calor terapéutico</h3>\n        <p>Dilata los vasos sanguíneos y relaja la fibra muscular antes del impacto, para que la percusión llegue más profundo y con menos molestia.</p>\n      </div>\n      <div class=\"pillar\">\n        <div class=\"step-no\">02 · PERCUSIÓN</div>\n        <div class=\"icon-wrap\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><path d=\"M12 3v6M12 3l-3 3M12 3l3 3M6 15a6 6 0 1012 0\"/></svg></div>\n        <h3>Percusión profunda</h3>\n        <p>Hasta 3.200 pulsaciones por minuto que rompen los nudos musculares y activan el riego sanguíneo en la zona tratada.</p>\n      </div>\n      <div class=\"pillar\">\n        <div class=\"step-no\">03 · LUZ ROJA</div>\n        <div class=\"icon-wrap\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><circle cx=\"12\" cy=\"12\" r=\"4\"/><path d=\"M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1\"/></svg></div>\n        <h3>Luz roja infrarroja</h3>\n        <p>Penetra en el tejido para acelerar la regeneración celular, reduciendo la inflamación tras el esfuerzo.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section id=\"comparativa\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <div class=\"eyebrow\">La diferencia</div>\n      <h2>No es una pistola de masaje más</h2>\n      <p class=\"lead\">La mayoría solo golpea. THERAPULSE combina las tres terapias que de verdad marcan la diferencia en la recuperación.</p>\n    </div>\n    <div class=\"compare-wrap\">\n      <table>\n        <thead>\n          <tr><th></th><th class=\"col-brand\">THERAPULSE</th><th>Pistola estándar</th><th>Sesión de fisio</th></tr>\n        </thead>\n        <tbody>\n          <tr><td>Percusión profunda</td><td class=\"check\">Sí</td><td class=\"check\">Sí</td><td class=\"check\">Sí</td></tr>\n          <tr><td>Calor terapéutico</td><td class=\"check\">Sí</td><td class=\"cross\">No</td><td class=\"check\">Depende</td></tr>\n          <tr><td>Luz roja infrarroja</td><td class=\"check\">Sí</td><td class=\"cross\">No</td><td class=\"cross\">No suele incluirse</td></tr>\n          <tr><td>Disponible en casa, cuando quieras</td><td class=\"check\">Sí</td><td class=\"check\">Sí</td><td class=\"cross\">Con cita previa</td></tr>\n          <tr><td>Coste por uso</td><td class=\"check\">Una vez, 49€</td><td class=\"check\">Una vez, 40–60€</td><td class=\"cross\">30–50€ por sesión</td></tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</section>\n\n<section style=\"background:var(--bg-alt); border-top:1px solid var(--border); border-bottom:1px solid var(--border);\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <div class=\"eyebrow\">En la práctica</div>\n      <h2>Cómo se usa</h2>\n    </div>\n    <div class=\"use-steps\">\n      <div class=\"use-step\"><div class=\"num\">1</div><h3>Elige la zona</h3><p style=\"color:var(--text-muted); font-size:14.5px;\">Piernas, espalda, cuello u hombros. Selecciona una de las 6 cabezales intercambiables.</p></div>\n      <div class=\"use-step\"><div class=\"num\">2</div><h3>Activa calor y luz</h3><p style=\"color:var(--text-muted); font-size:14.5px;\">Un botón enciende ambas terapias a la vez. En 10 segundos notas el calor.</p></div>\n      <div class=\"use-step\"><div class=\"num\">3</div><h3>Trabaja 2–3 minutos</h3><p style=\"color:var(--text-muted); font-size:14.5px;\">Desliza sobre el músculo sin presionar. Batería para más de 6 sesiones.</p></div>\n    </div>\n  </div>\n</section>\n\n<section id=\"opiniones\">\n  <div class=\"wrap\">\n    <div class=\"section-head center\" style=\"margin-left:auto; margin-right:auto;\">\n      <div class=\"eyebrow\" style=\"justify-content:center;\">Opiniones</div>\n      <h2>Gente que ya recupera mejor</h2>\n    </div>\n    <div class=\"testi-grid\">\n      <div class=\"testi-card\">\n        <div class=\"stars\">★★★★★</div>\n        <p>Corro 4 veces por semana y las piernas ya no me pesan al día siguiente. El calor se nota desde el primer minuto.</p>\n        <div class=\"testi-who\"><div class=\"avatar\">M</div><div><div class=\"name\">Marta</div><div class=\"role\">Runner</div></div></div>\n      </div>\n      <div class=\"testi-card\">\n        <div class=\"stars\">★★★★★</div>\n        <p>Trabajo 8 horas sentado y lo uso en el cuello cada tarde. Es la diferencia entre llegar a casa agarrotado o no.</p>\n        <div class=\"testi-who\"><div class=\"avatar\">D</div><div><div class=\"name\">David</div><div class=\"role\">Oficinista</div></div></div>\n      </div>\n      <div class=\"testi-card\">\n        <div class=\"stars\">★★★★★</div>\n        <p>Después de WOD lo paso por hombros y espalda. La luz roja marca la diferencia frente a las pistolas normales que ya había probado.</p>\n        <div class=\"testi-who\"><div class=\"avatar\">L</div><div><div class=\"name\">Lucía</div><div class=\"role\">CrossFit</div></div></div>\n      </div>\n      <div class=\"testi-card\">\n        <div class=\"stars\">★★★★★</div>\n        <p>Se lo recomiendo a varios pacientes como complemento entre sesiones. La combinación de calor y percusión tiene sentido clínico.</p>\n        <div class=\"testi-who\"><div class=\"avatar\">R</div><div><div class=\"name\">Rubén</div><div class=\"role\">Fisioterapeuta</div></div></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section id=\"garantia\">\n  <div class=\"wrap\">\n    <div class=\"trust-band\">\n      <div>\n        <div class=\"eyebrow\">Compra sin riesgo</div>\n        <h2 style=\"margin-top:14px;\">30 días para probarlo</h2>\n        <p class=\"lead\">Si no notas la diferencia en tu recuperación, te devolvemos el importe completo. Sin preguntas, sin letra pequeña.</p>\n      </div>\n      <div class=\"trust-icons\">\n        <div class=\"trust-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><path d=\"M12 2 4 6v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V6l-8-4z\"/></svg><span>Pago seguro SSL</span></div>\n        <div class=\"trust-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><rect x=\"3\" y=\"7\" width=\"18\" height=\"13\" rx=\"2\"/><path d=\"M16 7V5a4 4 0 00-8 0v2\"/></svg><span>Devolución garantizada</span></div>\n        <div class=\"trust-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><path d=\"M3 12h4l3 9 4-18 3 9h4\"/></svg><span>Soporte por email 24/48h</span></div>\n        <div class=\"trust-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"1.8\"><path d=\"M20.84 4.6a5.5 5.5 0 00-7.78 0L12 5.66l-1.06-1.05a5.5 5.5 0 10-7.78 7.78L12 21l8.84-8.6a5.5 5.5 0 000-7.78z\"/></svg><span>+2.400 clientes</span></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section id=\"faq\">\n  <div class=\"wrap\" style=\"max-width:800px;\">\n    <div class=\"section-head\">\n      <div class=\"eyebrow\">Preguntas frecuentes</div>\n      <h2>Todo lo que debes saber</h2>\n    </div>\n    <div id=\"faq-list\">\n      <div class=\"faq-item open\">\n        <button class=\"faq-q\">¿Es seguro usar calor y luz roja a diario?<span class=\"plus\">+</span></button>\n        <div class=\"faq-a\"><p>Sí. Las sesiones recomendadas son de 2 a 3 minutos por zona, hasta dos veces al día. El dispositivo se apaga solo si detecta sobrecalentamiento.</p></div>\n      </div>\n      <div class=\"faq-item\">\n        <button class=\"faq-q\">¿Cuánto dura la batería?<span class=\"plus\">+</span></button>\n        <div class=\"faq-a\"><p>Una carga completa (2 horas) ofrece entre 6 y 8 sesiones de uso combinado con calor y luz.</p></div>\n      </div>\n      <div class=\"faq-item\">\n        <button class=\"faq-q\">¿Cuánto tarda en llegar el pedido?<span class=\"plus\">+</span></button>\n        <div class=\"faq-a\"><p>El envío estándar tarda entre 3 y 6 días laborables. Recibirás un número de seguimiento por email en cuanto se despache.</p></div>\n      </div>\n      <div class=\"faq-item\">\n        <button class=\"faq-q\">¿Qué pasa si no me convence?<span class=\"plus\">+</span></button>\n        <div class=\"faq-a\"><p>Tienes 30 días desde la recepción para solicitar la devolución del importe completo, sin necesidad de justificar el motivo.</p></div>\n      </div>\n      <div class=\"faq-item\">\n        <button class=\"faq-q\">¿Incluye los cabezales intercambiables?<span class=\"plus\">+</span></button>\n        <div class=\"faq-a\"><p>Sí, el pedido incluye 6 cabezales pensados para distintas zonas: piernas, espalda, cuello y puntos de mayor tensión.</p></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section id=\"comprar\">\n  <div class=\"wrap\">\n    <div class=\"final-cta\">\n      <div class=\"eyebrow\" style=\"justify-content:center;\">Última llamada</div>\n      <h2>Empieza a recuperar mejor 