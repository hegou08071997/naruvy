{% comment %}
  CloudVaultUS — Custom Full-Width Hero Section
  File: sections/cvus-hero.liquid
  Add via: Shopify Theme Editor → Add section → CloudVaultUS Hero
{% endcomment %}

<section class="cvus-hero" id="cvus-hero-{{ section.id }}">
  {%- if section.settings.video_url != blank -%}
    <video
      class="cvus-hero__video"
      autoplay muted loop playsinline
      poster="{{ section.settings.image | image_url: width: 1920 }}"
    >
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- elsif section.settings.image != blank -%}
    <div class="cvus-hero__image">
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.image.alt
      }}
    </div>
  {%- else -%}
    <div class="cvus-hero__image cvus-hero__image--placeholder"></div>
  {%- endif -%}

  <div class="cvus-hero__overlay"></div>

  <div class="cvus-hero__content page-width">
    {%- if section.settings.eyebrow != blank -%}
      <span class="cvus-hero__eyebrow cvus-eyebrow">
        {{ section.settings.eyebrow }}
      </span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="cvus-hero__heading cvus-gradient-text">
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="cvus-hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="cvus-hero__cta-group">
      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a
          href="{{ section.settings.cta_url }}"
          class="button cvus-hero__cta-primary"
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.cta2_label != blank and section.settings.cta2_url != blank -%}
        <a
          href="{{ section.settings.cta2_url }}"
          class="button button--secondary cvus-hero__cta-secondary"
        >
          {{ section.settings.cta2_label }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.show_scroll_indicator -%}
      <div class="cvus-hero__scroll-indicator" aria-hidden="true">
        <span></span>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #cvus-hero-{{ section.id }} {
    min-height: {{ section.settings.height }}vh;
  }

  #cvus-hero-{{ section.id }} .cvus-hero__overlay {
    background: linear-gradient(
      to bottom,
      rgba(9, 9, 11, {{ section.settings.overlay_top_opacity | divided_by: 100.0 }}) 0%,
      rgba(9, 9, 11, {{ section.settings.overlay_mid_opacity  | divided_by: 100.0 }}) 50%,
      rgba(9, 9, 11, {{ section.settings.overlay_bot_opacity  | divided_by: 100.0 }}) 100%
    );
  }
</style>

{% stylesheet %}
/* ── HERO SECTION ────────────────────────────────────────── */
.cvus-hero {
  position: relative;
  width: 100%;
  min-height: 90vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background-color: var(--cvus-bg);
}

/* Background image */
.cvus-hero__image {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.cvus-hero__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transform: scale(1.03);
  transition: transform 8s ease;
}

.cvus-hero:hover .cvus-hero__image img {
  transform: scale(1.08);
}

/* Placeholder background when no image set */
.cvus-hero__image--placeholder {
  background: linear-gradient(135deg, #0a0a0f 0%, #1a1020 50%, #0a0a0f 100%);
}

/* Background video */
.cvus-hero__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}

/* Gradient overlay */
.cvus-hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

/* Content */
.cvus-hero__content {
  position: relative;
  z-index: 2;
  max-width: 760px;
  padding: 8rem 2rem;
}

/* Eyebrow */
.cvus-hero__eyebrow {
  margin-bottom: 1.2rem;
  animation: cvus-fade-up 0.6s ease both;
}

/* Main heading */
.cvus-hero__heading {
  font-size: clamp(3rem, 8vw, 6.5rem) !important;
  line-height: 0.95 !important;
  margin: 0 0 1.5rem !important;
  animation: cvus-fade-up 0.7s 0.1s ease both;
}

/* Subheading */
.cvus-hero__subheading {
  font-size: clamp(0.95rem, 1.8vw, 1.15rem);
  color: var(--cvus-text-sub);
  max-width: 520px;
  line-height: 1.7;
  margin: 0 0 2.5rem;
  animation: cvus-fade-up 0.7s 0.2s ease both;
}

/* CTA buttons */
.cvus-hero__cta-group {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  animation: cvus-fade-up 0.7s 0.3s ease both;
}

.cvus-hero__cta-primary {
  padding: 16px 36px !important;
  font-size: 0.85rem !important;
}

.cvus-hero__cta-secondary {
  padding: 16px 36px !important;
  font-size: 0.85rem !important;
}

/* Scroll indicator */
.cvus-hero__scroll-indicator {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
}

.cvus-hero__scroll-indicator span {
  display: block;
  width: 22px;
  height: 36px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-radius: 11px;
  position: relative;
}

.cvus-hero__scroll-indicator span::after {
  content: '';
  display: block;
  width: 4px;
  height: 8px;
  background: var(--cvus-red);
  border-radius: 2px;
  margin: 5px auto 0;
  animation: cvus-scroll-dot 1.8s ease infinite;
}

/* Animations */
@keyframes cvus-fade-up {
  from {
    opacity: 0;
    transform: translateY(24px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cvus-scroll-dot {
  0%   { opacity: 1; transform: translateY(0); }
  80%  { opacity: 0; transform: translateY(12px); }
  100% { opacity: 0; transform: translateY(0); }
}

/* Mobile */
@media (max-width: 749px) {
  .cvus-hero__content   { padding: 6rem 1.5rem 5rem; max-width: 100%; }
  .cvus-hero__heading   { font-size: clamp(2.4rem, 10vw, 3.5rem) !important; }
  .cvus-hero__cta-group { flex-direction: column; }
  .cvus-hero__cta-primary,
  .cvus-hero__cta-secondary { text-align: center !important; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "CloudVaultUS Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background video URL (.mp4)",
      "info": "Overrides image if set. Use a hosted .mp4 URL."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Premium Vape Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate Your Experience"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover CloudVaultUS — curated premium vapes sourced directly from top manufacturers."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Button 2 label",
      "default": "View Collections"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Button 2 URL",
      "default": "/collections"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Hero height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 90
    },
    {
      "type": "header",
      "content": "Overlay opacity"
    },
    {
      "type": "range",
      "id": "overlay_top_opacity",
      "label": "Top opacity %",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "overlay_mid_opacity",
      "label": "Middle opacity %",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "overlay_bot_opacity",
      "label": "Bottom opacity %",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 90
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "CloudVaultUS Hero"
    }
  ]
}
{% endschema %}
