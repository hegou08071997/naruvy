{%- if section.settings.show_top_divider -%}
  <div class="vopt-divider"><hr></div>
{%- endif -%}

<section class="vopt-final vopt-wrap">
  {%- if section.settings.button_link != blank -%}
    <a href="{{ section.settings.button_link }}" class="vopt-btn">{{ section.settings.button_label | escape }}</a>
  {%- else -%}
    <button type="button" class="vopt-btn vopt-scroll-btn">{{ section.settings.button_label | escape }}</button>
  {%- endif -%}
  {%- if section.settings.consent != blank -%}
    <p class="vopt-final-consent">{{ section.settings.consent | escape }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Vault Final CTA",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show divider above section",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "GET INSTANT ACCESS →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link (optional)",
      "info": "Leave blank to scroll the visitor to the opt-in form and focus the first name field."
    },
    {
      "type": "text",
      "id": "consent",
      "label": "Consent line",
      "default": "Free. No credit card. Unsubscribe anytime."
    }
  ],
  "presets": [{ "name": "Vault Final CTA" }]
}
{% endschema %}
