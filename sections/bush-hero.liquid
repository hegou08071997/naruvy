{%- style -%}
  #BushHero-{{ section.id }} .bush-hero__overlay {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

{%- liquid
  assign padding_class = 'bush-hero--padding-' | append: section.settings.padding_vertical
-%}

<div
  id="BushHero-{{ section.id }}"
  class="bush-hero {{ padding_class }}"
>
  <div class="bush-hero__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1800
        | image_tag:
          loading: 'eager',
          widths: '375, 750, 1100, 1500, 1800',
          sizes: '100vw',
          class: 'bush-hero__img'
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg bush-hero__img' }}
    {%- endif -%}
    <div class="bush-hero__overlay"></div>
  </div>

  <div class="bush-hero__content page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="bush-hero__heading h1">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="bush-hero__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
    {%- if section.settings.button_1_label != blank or section.settings.button_2_label != blank -%}
      <div class="bush-hero__buttons">
        {%- if section.settings.button_1_label != blank -%}
          <a
            {% if section.settings.button_1_link != blank %}
              href="{{ section.settings.button_1_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
            class="button button--primary"
          >
            {{- section.settings.button_1_label | escape -}}
          </a>
        {%- endif -%}
        {%- if section.settings.button_2_label != blank -%}
          <a
            {% if section.settings.button_2_link != blank %}
              href="{{ section.settings.button_2_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
            class="button button--secondary"
          >
            {{- section.settings.button_2_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Bush Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ride the bush"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Gear built for where the trail ends"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 40
    },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Section height",
      "options": [
        { "value": "small",  "label": "Small"  },
        { "value": "medium", "label": "Medium" },
        { "value": "large",  "label": "Large"  }
      ],
      "default": "large"
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Bush Hero"
    }
  ]
}
{% endschema %}
