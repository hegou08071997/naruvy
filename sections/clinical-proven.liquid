{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .cp-section {
    position: relative;
    overflow: hidden;
    background-color: var(--cp-bg-color, #014c3e);
    color: var(--cp-text-color, #fff);
  }

  .cp-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: var(--cp-img-opacity, 1);
    pointer-events: none;
  }

  .cp-content {
    position: relative;
  }

  .cp-layout {
    display: flex;
    flex-wrap: wrap;
    gap: 62px;
    align-items: flex-start;
  }

  /* Stats grid */
  .cp-stats {
    display: flex;
    text-align: left;
    width: 100%;
    max-width: 55%;
    flex-wrap: wrap;
  }

  .cp-stat {
    text-align: left;
    width: 50%;
    position: relative;
  }

  .cp-stat:nth-child(n+3) {
    border-top: 1px solid rgba(255, 255, 255, 0.3);
    padding-top: 13px;
    margin-top: 13px;
  }

  .cp-stat__pct {
    font-weight: 500;
    font-size: 39.86px;
    line-height: 42px;
    letter-spacing: 0;
    background: linear-gradient(0deg, var(--cp-pct-color, #E3FFDE), var(--cp-pct-color, #E3FFDE));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cp-stat__head {
    font-weight: 700;
    font-size: 16px;
    line-height: 22px;
    letter-spacing: 0;
    margin-bottom: 4px;
    width: 100%;
    display: inline-block;
  }

  .cp-stat:nth-child(3) .cp-stat__head {
    display: block;
  }

  .cp-stat__caption {
    font-weight: 400;
    font-size: 15px;
    line-height: 18px;
    letter-spacing: 0;
    margin-bottom: 0;
    display: inline-block;
  }

  /* CTA area */
  .cp-cta {
    width: calc(45% - 62px);
    text-align: center;
  }

  .cp-cta__heading {
    font-weight: 500;
    font-size: var(--cp-heading-size, 31px);
    line-height: 1.23;
    letter-spacing: 0;
    text-align: center;
    text-transform: capitalize;
    margin: 0 0 20px;
    color: var(--cp-text-color, #fff);
  }

  .cp-cta__heading strong {
    font-weight: 500;
    display: inline-block;
    width: 100%;
    color: var(--cp-highlight-color, #E3FFDE);
  }

  .cp-cta__subtitle {
    font-weight: 400;
    font-size: 17px;
    line-height: 18px;
    letter-spacing: 0;
    text-align: center;
    margin: 0 0 25px;
    max-width: 430px;
    margin-left: auto;
    margin-right: auto;
  }

  .cp-cta__btn {
    display: flex;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
    height: 45px;
    align-items: center;
    justify-content: center;
    border-radius: 5px;
    background-color: var(--cp-cta-bg, #E3FFDE);
    color: var(--cp-cta-text, #014c3e);
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    padding: 0 24px;
    border: none;
    cursor: pointer;
  }

  .cp-cta__guarantee {
    font-size: 14px;
    line-height: 17.6px;
    margin: 8px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5.7px;
  }

  .cp-cta__guarantee svg {
    flex-shrink: 0;
  }

  /* Mobile CTA (inside stats, shown only on mobile) */
  .cp-cta--mobile {
    display: none;
  }

  /* Desktop: hide mobile CTA, show desktop CTA */
  .cp-cta--desktop {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .cp-layout {
      gap: 25px;
      flex-direction: column-reverse;
    }

    .cp-cta {
      width: 100%;
    }

    .cp-stats {
      width: 100%;
      max-width: 100%;
    }

    .cp-stat {
      width: 100%;
    }

    .cp-stat:nth-child(n+2) {
      border-top: 1px solid rgba(255, 255, 255, 0.3);
      padding-top: 23px;
      margin-top: 25px;
    }

    .cp-cta__heading {
      font-size: 26px;
      line-height: 32px;
      margin-bottom: 13px;
      text-align: left;
      max-width: 250px;
    }

    .cp-cta__subtitle {
      font-size: 16px;
      text-align: left;
      margin-bottom: 0;
    }

    .cp-cta--desktop .cp-cta__btn,
    .cp-cta--desktop .cp-cta__guarantee {
      display: none;
    }

    .cp-cta--mobile {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-top: 40px;
    }

    .cp-stat__caption br {
      display: none;
    }
  }
</style>

<div
  class="section-{{ section.id }}-padding cp-section"
  style="
    --cp-bg-color: {{ section.settings.bg_color }};
    --cp-text-color: {{ section.settings.text_color }};
    --cp-pct-color: {{ section.settings.percentage_color }};
    --cp-highlight-color: {{ section.settings.highlight_color }};
    --cp-heading-size: {{ section.settings.heading_size }}px;
    --cp-img-opacity: {{ section.settings.image_opacity | divided_by: 100.0 }};
    --cp-cta-bg: {{ section.settings.cta_bg_color }};
    --cp-cta-text: {{ section.settings.cta_text_color }};
  "
>
  {%- if section.settings.bg_image != blank -%}
    <img
      class="cp-bg-image"
      src="{{ section.settings.bg_image | image_url: width: 1900 }}"
      alt=""
      loading="lazy"
      width="{{ section.settings.bg_image.width }}"
      height="{{ section.settings.bg_image.height }}"
    >
  {%- endif -%}

  <div class="cp-content page-width"
    data-cp-function="{{ section.settings.cta_function }}"
    data-cp-link="{{ section.settings.cta_url }}"
  >
    <div class="cp-layout">
      <div class="cp-stats" id="cp-stats-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="cp-stat" {{ block.shopify_attributes }}>
            <div class="cp-stat__pct" data-cp-target="{{ block.settings.percentage }}">0%</div>
            <span class="cp-stat__head">{{ block.settings.heading }}</span>
            <span class="cp-stat__caption">{{ block.settings.caption }}</span>
          </div>
        {%- endfor -%}

        {%- if section.settings.cta_text != blank -%}
          <div class="cp-cta--mobile">
            <a href="#" class="cp-cta__btn" data-cp-btn>{{ section.settings.cta_text }}</a>
            {%- if section.settings.guarantee_text != blank -%}
              <div class="cp-cta__guarantee">
                <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2.7179 3.96923V7.40687C2.71738 11.0519 5.00315 14.3807 8.4064 15.6896C8.68102 15.7954 8.97001 15.8477 9.25901 15.8477C9.548 15.8477 9.83699 15.7949 10.1121 15.6896L10.6224 15.493C13.7679 14.2832 15.8006 11.2403 15.8001 7.74155V3.96923C15.8001 3.68691 15.5768 3.4549 15.295 3.44412C13.4055 3.37071 11.4791 2.6259 9.56905 1.23124C9.38425 1.09675 9.13376 1.09675 8.94897 1.23124C7.03843 2.6259 5.11197 3.37071 3.22299 3.44412C2.94119 3.4549 2.7179 3.68691 2.7179 3.96923ZM3.76915 4.46098C5.60065 4.288 7.44343 3.5632 9.25901 2.30097C11.0741 3.5632 12.9174 4.288 14.7489 4.46098V7.74155C14.7494 10.8019 12.9815 13.4593 10.2446 14.5116L9.73484 14.7082C9.42789 14.8263 9.08961 14.8263 8.78368 14.7082C5.7839 13.5543 3.76864 10.6202 3.76915 7.40687V4.46098Z" fill="currentColor"/>
                  <path d="M8.1826 10.6602C8.28116 10.7587 8.41462 10.8142 8.55424 10.8142C8.69386 10.8142 8.82732 10.7587 8.92587 10.6602L12.1951 7.39092C12.4005 7.18559 12.4005 6.85297 12.1951 6.64765C11.9898 6.44232 11.6572 6.44232 11.4519 6.64765L8.55424 9.54528L7.06615 8.05668C6.86082 7.85136 6.5282 7.85136 6.32288 8.05668C6.11755 8.26201 6.11755 8.59463 6.32288 8.79995L8.1826 10.6602Z" fill="currentColor"/>
                </svg>
                {{ section.settings.guarantee_text }}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div class="cp-cta cp-cta--desktop">
        {%- if section.settings.heading != blank -%}
          <h2 class="cp-cta__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="cp-cta__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.cta_text != blank -%}
          <a href="#" class="cp-cta__btn" data-cp-btn>{{ section.settings.cta_text }}</a>
        {%- endif -%}
        {%- if section.settings.guarantee_text != blank -%}
          <div class="cp-cta__guarantee">
            <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.7179 3.96923V7.40687C2.71738 11.0519 5.00315 14.3807 8.4064 15.6896C8.68102 15.7954 8.97001 15.8477 9.25901 15.8477C9.548 15.8477 9.83699 15.7949 10.1121 15.6896L10.6224 15.493C13.7679 14.2832 15.8006 11.2403 15.8001 7.74155V3.96923C15.8001 3.68691 15.5768 3.4549 15.295 3.44412C13.4055 3.37071 11.4791 2.6259 9.56905 1.23124C9.38425 1.09675 9.13376 1.09675 8.94897 1.23124C7.03843 2.6259 5.11197 3.37071 3.22299 3.44412C2.94119 3.4549 2.7179 3.68691 2.7179 3.96923ZM3.76915 4.46098C5.60065 4.288 7.44343 3.5632 9.25901 2.30097C11.0741 3.5632 12.9174 4.288 14.7489 4.46098V7.74155C14.7494 10.8019 12.9815 13.4593 10.2446 14.5116L9.73484 14.7082C9.42789 14.8263 9.08961 14.8263 8.78368 14.7082C5.7839 13.5543 3.76864 10.6202 3.76915 7.40687V4.46098Z" fill="currentColor"/>
              <path d="M8.1826 10.6602C8.28116 10.7587 8.41462 10.8142 8.55424 10.8142C8.69386 10.8142 8.82732 10.7587 8.92587 10.6602L12.1951 7.39092C12.4005 7.18559 12.4005 6.85297 12.1951 6.64765C11.9898 6.44232 11.6572 6.44232 11.4519 6.64765L8.55424 9.54528L7.06615 8.05668C6.86082 7.85136 6.5282 7.85136 6.32288 8.05668C6.11755 8.26201 6.11755 8.59463 6.32288 8.79995L8.1826 10.6602Z" fill="currentColor"/>
            </svg>
            {{ section.settings.guarantee_text }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var statsContainer = document.getElementById('cp-stats-{{ section.id }}');
    if (!statsContainer) return;

    var animated = false;

    var observer = new IntersectionObserver(function(entries, obs) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !animated) {
          animated = true;
          var els = statsContainer.querySelectorAll('[data-cp-target]');
          els.forEach(function(el) {
            var target = parseInt(el.getAttribute('data-cp-target'), 10) || 0;
            var duration = 1000;
            var startTime = null;

            function step(timestamp) {
              if (!startTime) startTime = timestamp;
              var progress = Math.min((timestamp - startTime) / duration, 1);
              var eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.round(eased * target) + '%';
              if (progress < 1) requestAnimationFrame(step);
            }

            requestAnimationFrame(step);
          });
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    observer.observe(statsContainer);

    /* CTA button handling — same pattern as sticky cart */
    var cpContent = document.querySelector('.cp-content[data-cp-function]');
    if (cpContent) {
      var cpFunction = cpContent.getAttribute('data-cp-function') || 'link';
      var cpLink = cpContent.getAttribute('data-cp-link');
      var cpBtns = cpContent.querySelectorAll('[data-cp-btn]');

      cpBtns.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          if (cpFunction === 'add_to_cart') {
            var productForm = document.querySelector('product-form');
            if (productForm && productForm.form) {
              productForm.form.requestSubmit();
            }
          } else {
            var target = cpLink || '';
            if (target && target.charAt(0) === '#') {
              var dest = document.querySelector(target);
              if (dest) dest.scrollIntoView({ behavior: 'smooth' });
            } else if (target) {
              window.location.href = target;
            } else {
              /* Default: scroll to product info section */
              var dest = document.querySelector('[id^="ProductInfo-"]');
              if (dest) dest.scrollIntoView({ behavior: 'smooth' });
            }
          }
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Clinical proven",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#014c3e"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "image_opacity",
      "label": "Image opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "percentage_color",
      "label": "Percentage color",
      "default": "#E3FFDE"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Heading highlight color",
      "default": "#E3FFDE"
    },
    {
      "type": "header",
      "content": "CTA content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<strong>Clinically Proven.</strong> More Energy. A Healthier Gut."
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 44,
      "step": 1,
      "unit": "px",
      "label": "Heading size",
      "default": 31
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "When clean, plant-based ingredients meet clinical potency, the results speak for themselves."
    },
    {
      "type": "select",
