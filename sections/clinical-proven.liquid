      "label": "Button function",
      "options": [
        { "value": "link", "label": "Link / scroll to section" },
        { "value": "add_to_cart", "label": "Add to cart" }
      ],
      "default": "link"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Try Risk-Free Today"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link",
      "info": "Leave empty to scroll to product form. Use anchor links like #SectionId to scroll to a specific section."
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "Button background color",
      "default": "#E3FFDE"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#014c3e"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "30-day money back guarantee"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 84
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 80
