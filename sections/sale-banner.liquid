{%- style -%}
  .sale-banner-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    width: 100%;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    box-sizing: border-box;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    position: relative;
  }

  .sale-banner-{{ section.id }} .sale-banner__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
  }

  .sale-banner-{{ section.id }} .sale-banner__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .sale-banner-{{ section.id }} .sale-banner__heading {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_font_size }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    text-transform: {{ section.settings.heading_transform }};
    margin: 0;
    line-height: 1.3;
    white-space: nowrap;
  }

  .sale-banner-{{ section.id }} .sale-banner__subtext {
    color: {{ section.settings.subtext_color }};
    font-size: {{ section.settings.subtext_font_size }}px;
    font-weight: {{ section.settings.subtext_font_weight }};
    letter-spacing: 0.5px;
    margin: 0;
    line-height: 1.3;
  }

  .sale-banner-{{ section.id }} .sale-banner__timer {
    display: flex;
    align-items: center;
    gap: 4px;
    color: {{ section.settings.timer_color }};
    flex-shrink: 0;
  }

  .sale-banner-{{ section.id }} .sale-banner__time-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 32px;
  }

  .sale-banner-{{ section.id }} .sale-banner__digits {
    font-size: 20px;
    letter-spacing: 1px;
    line-height: 1.2;
    font-variant-numeric: tabular-nums;
  }

  .sale-banner-{{ section.id }} .sale-banner__label {
    font-size: 9px;
    font-weight: 400;
    text-transform: capitalize;
    letter-spacing: 0.5px;
    opacity: 0.85;
    line-height: 1.2;
  }

  .sale-banner-{{ section.id }} .sale-banner__colon {
    font-size: 20px;
    line-height: 1;
    padding-bottom: 12px;
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    .sale-banner-{{ section.id }} {
      padding: 8px 12px;
    }

    .sale-banner-{{ section.id }} .sale-banner__inner {
      gap: 14px;
    }

    .sale-banner-{{ section.id }} .sale-banner__heading {
      font-size: {{ section.settings.heading_font_size | times: 0.75 | round: 0 }}px;
      letter-spacing: {{ section.settings.heading_letter_spacing | times: 0.6 | round: 1 }}px;
    }

    .sale-banner-{{ section.id }} .sale-banner__subtext {
      font-size: {{ section.settings.subtext_font_size | times: 0.75 | round: 0 }}px;
    }

    .sale-banner-{{ section.id }} .sale-banner__digits {
      font-size: 15px;
    }

    .sale-banner-{{ section.id }} .sale-banner__label {
      font-size: 7px;
    }

    .sale-banner-{{ section.id }} .sale-banner__colon {
      font-size: 15px;
      padding-bottom: 10px;
    }

    .sale-banner-{{ section.id }} .sale-banner__time-block {
      min-width: 24px;
    }
  }
{%- endstyle -%}

<div class="sale-banner-{{ section.id }}" id="sale-banner-{{ section.id }}" {% if section.settings.show_timer %}style="display:none;"{% endif %}>
  <div class="sale-banner__inner">
    <div class="sale-banner__text">
      {% if section.settings.heading != blank %}
        <p class="sale-banner__heading">{{ section.settings.heading }}</p>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="sale-banner__subtext">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    {% if section.settings.show_timer %}
      <div class="sale-banner__timer">
        <div class="sale-banner__time-block">
          <span class="sale-banner__digits" data-timer-hours>00</span>
          <span class="sale-banner__label">Hrs</span>
        </div>
        <span class="sale-banner__colon">:</span>
        <div class="sale-banner__time-block">
          <span class="sale-banner__digits" data-timer-mins>00</span>
          <span class="sale-banner__label">Mins</span>
        </div>
        <span class="sale-banner__colon">:</span>
        <div class="sale-banner__time-block">
          <span class="sale-banner__digits" data-timer-secs>00</span>
          <span class="sale-banner__label">Secs</span>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% if section.settings.show_timer %}
<script>
  (function () {
    var DURATION = {{ section.settings.timer_hours }} * 60 * 60 * 1000;
    var KEY = 'sale_timer_end_{{ section.id }}';

    function getCookie(n) {
      var m = document.cookie.match(new RegExp('(^| )' + n + '=([^;]+)'));
      return m ? Number(m[2]) : null;
    }

    function setCookie(n, v) {
      var exp = new Date(Date.now() + DURATION + 60000).toUTCString();
      document.cookie = n + '=' + v + ';path=/;expires=' + exp + ';SameSite=Lax';
    }

    var endTime = getCookie(KEY);

    if (!endTime || isNaN(endTime)) {
      endTime = Date.now() + DURATION;
      setCookie(KEY, endTime);
    }

    var banner = document.getElementById('sale-banner-{{ section.id }}');
    var elH = banner.querySelector('[data-timer-hours]');
    var elM = banner.querySelector('[data-timer-mins]');
    var elS = banner.querySelector('[data-timer-secs]');

    function tick() {
      var left = endTime - Date.now();
      if (left <= 0) {
        banner.style.display = 'none';
        return;
      }
      elH.textContent = String(Math.floor(left / 3600000)).padStart(2, '0');
      elM.textContent = String(Math.floor((left % 3600000) / 60000)).padStart(2, '0');
      elS.textContent = String(Math.floor((left % 60000) / 1000)).padStart(2, '0');
    }

    if (endTime - Date.now() > 0) {
      banner.style.display = 'block';
      tick();
      setInterval(tick, 1000);
    }
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "Sale banner",
  "tag": "section",
  "class": "section-sale-banner",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "ST PATRICK'S DAY SALE"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 2.5
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Subtext"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Shop Now and Get Up To 70% Off"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#ffffffe6"
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "label": "Subtext font size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "subtext_font_weight",
      "label": "Subtext font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Timer"
    },
    {
      "type": "checkbox",
      "id": "show_timer",
      "label": "Show countdown timer",
      "default": true
    },
    {
      "type": "range",
      "id": "timer_hours",
      "label": "Timer duration (hours)",
      "min": 1,
      "max": 72,
      "step": 1,
      "unit": "h",
      "default": 2,
      "info": "Starts on first visit, persists via cookie on refresh. New browser = fresh timer."
    },
    {
      "type": "color",
      "id": "timer_color",
      "label": "Timer color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#2E5BFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Sale banner"
    }
  ]
}
{% endschema %}
