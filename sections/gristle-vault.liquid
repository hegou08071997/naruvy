            "video_tag": "Solo Guitar · Arrangement"
          }
        },
        {
          "type": "video",
          "settings": {
            "youtube_url": "https://www.youtube.com/watch?v=BmCQbpYT-T8",
            "video_title": "Clinic: Gear, Chord Techniques and Tonus Diabolicus",
            "video_description": "James Burton, Robben Ford, the Mahavishnu scale, hybrid picking reps.",
            "video_tag": "Clinic · Tone · Theory"
          }
        },
        {
