        { "type": "text", "id": "video_title", "label": "Video Title" },
        { "type": "textarea", "id": "video_description", "label": "Video Description" },
        { "type": "text", "id": "video_tag", "label": "Tag (e.g. Rhythm · Phrasing)" }
