          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "check", "label": "Check" },
            { "value": "bottle", "label": "Bottle" },
            { "value": "star", "label": "Star" },
            { "value": "plant", "label": "Plant" }
          ]
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Clean ingredients"
        }
      ]
    },
    {
      "type": "ritual_card",
      "name": "Ritual card",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "step",
