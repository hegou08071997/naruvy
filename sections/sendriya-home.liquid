    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Hero heading",
      "default": "Daily wellness, made beautifully simple."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Hero text",
      "default": "<p>Plant-forward supplements crafted for calm routines, clean nourishment, and everyday balance.</p>"
    },
    {
      "type": "product",
      "id": "hero_product",
      "label": "Hero product"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured collection"
    },
    {
      "type": "text",
      "id": "product_label",
      "label": "Product label",
      "default": "Featured supplement"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop supplements"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore rituals"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "collection_kicker",
      "label": "Collection kicker",
      "default": "Shop the essentials"
    },
    {
      "type": "inline_richtext",
      "id": "collection_heading",
      "label": "Collection heading",
      "default": "Small rituals. Real daily support."
    },
    {
      "type": "richtext",
      "id": "collection_text",
      "label": "Collection text",
      "default": "<p>Choose clean, considered supplements for energy, immunity, digestion, and balanced living.</p>"
    },
    {
      "type": "text",
      "id": "ritual_kicker",
      "label": "Ritual kicker",
      "default": "Nourish. Balance. Thrive."
    },
    {
      "type": "inline_richtext",
      "id": "ritual_heading",
      "label": "Ritual heading",
      "default": "A calmer way to shop wellness."
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
