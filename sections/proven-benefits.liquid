{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.settings.cta_note_icon == blank and section.settings.cta_note_icon_name != blank -%}
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet">
{%- endif -%}

<style>
  .proven-benefits {
    width: 100%;
    background: var(--pb-bg, #f1f3ea);
  }

  .pb-heading {
    font-weight: 500;
    font-size: 31px;
    line-height: 38px;
    letter-spacing: 0;
    margin: 0 0 19px;
    text-align: center;
  }

  .pb-heading strong {
    color: var(--pb-highlight, #009370);
  }

  .pb-subheading {
    max-width: 804px;
    margin: 0 auto 41px;
    font-weight: 400;
    font-size: 17px;
    line-height: 19px;
    letter-spacing: 0;
    text-align: center;
  }

  .pb-subheading strong {
    font-weight: 500;
  }

  .pb-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 16px;
  }

  .pb-card {
    width: calc(50% - 8px);
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.3);
    background: #fff;
    overflow: hidden;
    position: relative;
  }

  .pb-card__front {
    display: flex;
    align-items: center;
    padding: 10px 20px 10px 9px;
    cursor: pointer;
    justify-content: space-between;
    -webkit-user-select: none;
    user-select: none;
  }

  .pb-card__front-inner {
    display: flex;
    align-items: center;
    gap: 27px;
  }

  .pb-card__img {
    width: 125px;
    height: 119px;
    object-fit: cover;
    border-radius: 7px;
    flex-shrink: 0;
  }

  .pb-card__img-placeholder {
    width: 125px;
    height: 119px;
    border-radius: 7px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .pb-card__img-placeholder svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .pb-card__title {
    font-weight: 500;
    font-size: 25.59px;
    line-height: 28.72px;
    letter-spacing: 0;
    margin: 0 0 8px;
  }

  .pb-card__desc {
    font-weight: 400;
    font-size: 19.91px;
    line-height: 24.17px;
    letter-spacing: 0;
    margin: 0;
  }

  .pb-card__toggle {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border: 1px solid rgba(0, 0, 0, 0.3);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    background: none;
    cursor: pointer;
    padding: 0;
  }

  .pb-card__toggle .pb-icon-minus {
    display: none;
  }

  .pb-card.active .pb-card__toggle .pb-icon-plus {
    display: none;
  }

  .pb-card.active .pb-card__toggle .pb-icon-minus {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pb-card__answer {
    background: #fff;
    width: 85%;
    position: absolute;
    top: 0;
    bottom: 0;
    display: none;
    align-items: center;
    font-size: 17px;
    line-height: 23px;
    text-align: left;
    padding: 12.5px 31.5px 12.5px;
    border-radius: 8px;
    transition: all 0.5s ease;
    transform-style: preserve-3d;
    background: transparent;
    overflow: visible;
  }

  .pb-card__answer p {
    margin: 0;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    transform: rotateY(180deg);
  }

  .pb-card__front-inner {
    transition: all 0.5s ease;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .pb-card.active .pb-card__front-inner {
    transform: rotateY(180deg);
  }

  .pb-card.active .pb-card__answer {
    display: inline-flex;
    background: #fff;
    transform: rotateY(180deg);
    cursor: pointer;
  }

  .pb-card.active .pb-card__front {
    cursor: pointer;
  }

  .pb-card.closing .pb-card__front-inner {
    transform: rotateY(0deg);
  }

  .pb-card.closing .pb-card__answer {
    display: inline-flex;
    background: #fff;
    transform: rotateY(0deg);
  }

  /* Mobile CTA */
  .pb-cta {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .pb-cta {
      display: block;
      text-align: center;
      margin-top: 40px;
    }

    .pb-cta__button {
      display: block;
      width: 100%;
      padding: 16px 24px;
      background: var(--pb-highlight, #009370);
      color: #ffffff;
      font-size: 18px;
      font-weight: 600;
      font-style: italic;
      text-decoration: none;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      text-align: center;
    }

    .pb-cta__note {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 14px;
      margin-top: 12px;
      color: inherit;
    }

    .pb-cta__note img {
      width: 16px;
      height: 16px;
    }

    .pb-cta__icon {
      font-size: 18px;
      line-height: 1;
    }
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .pb-heading {
      font-size: 26px;
      line-height: 32px;
      margin-bottom: 10px;
      max-width: 220px;
      margin-left: auto;
      margin-right: auto;
    }

    .pb-subheading {
      font-size: 14px;
      margin-bottom: 40px;
    }

    .pb-grid {
      gap: 10px;
    }

    .pb-card {
      width: 100%;
      border-radius: 5.64px;
    }

    .pb-card__front {
      padding: 8px 16px 8px 8px;
    }

    .pb-card__front-inner {
      gap: 19px;
    }

    .pb-card__img {
      width: 88px;
      height: 84px;
      border-radius: 5px;
    }

    .pb-card__img-placeholder {
      width: 88px;
      height: 84px;
      border-radius: 5px;
    }

    .pb-card__title {
      font-size: 18px;
      line-height: 20.2px;
      margin-bottom: 5px;
    }

    .pb-card__desc {
      font-size: 14px;
      line-height: 17px;
    }

    .pb-card__toggle {
      width: 25px;
      height: 25px;
    }

    .pb-card__answer {
      font-size: 14px;
      line-height: 17px;
      padding: 19px 19px 19px 0;
    }
  }
</style>

<div
  class="section-{{ section.id }}-padding proven-benefits"
  style="
    --pb-bg: {{ section.settings.bg_color }};
    --pb-highlight: {{ section.settings.highlight_color }};
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="pb-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="pb-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="pb-grid">
      {%- for block in section.blocks -%}
        <div class="pb-card" {{ block.shopify_attributes }}>
          <div class="pb-card__front" data-pb-toggle>
            <div class="pb-card__front-inner">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'pb-card__img', widths: '125,250,300' }}
              {%- else -%}
                <div class="pb-card__img-placeholder">
                  {{ 'product-apparel-2' | placeholder_svg_tag }}
                </div>
              {%- endif -%}
              <div>
                {%- if block.settings.title != blank -%}
                  <h3 class="pb-card__title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="pb-card__desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </div>
            <button class="pb-card__toggle" type="button" aria-label="Expand">
              <span class="pb-icon-plus">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5.72069 11.033V5.96898H0.656637V5.38515H5.72069V0.321103H6.30451V5.38515H11.3686V5.96898H6.30451V11.033H5.72069Z" fill="black"/>
                </svg>
              </span>
              <span class="pb-icon-minus">
                <svg width="8" height="1" viewBox="0 0 8 1" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7.97719 0.0678547V0.65168H0.920525V0.0678547H7.97719Z" fill="black"/>
                </svg>
              </span>
            </button>
          </div>
          <div class="pb-card__answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="pb-cta">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="pb-cta__button">{{ section.settings.cta_text }}</a>
      {%- endif -%}
      {%- if section.settings.cta_note != blank -%}
        <p class="pb-cta__note">
          {%- if section.settings.cta_note_icon != blank -%}
            {{ section.settings.cta_note_icon | image_url: width: 32 | image_tag: widths: '16,32', loading: 'lazy' }}
          {%- elsif section.settings.cta_note_icon_name != blank -%}
            <span class="material-symbols-outlined pb-cta__icon">{{ section.settings.cta_note_icon_name }}</span>
          {%- endif -%}
          {{ section.settings.cta_note }}
        </p>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var section = document.querySelector('.section-{{ section.id }}-padding');
    if (!section) return;

    function closeCard(card) {
      card.classList.add('closing');
      card.classList.remove('active');
      setTimeout(function() {
        card.classList.remove('closing');
      }, 500);
    }

    section.addEventListener('click', function(e) {
      var card = e.target.closest('.pb-card');
      if (!card) return;
      var wasActive = card.classList.contains('active');
      section.querySelectorAll('.pb-card.active').forEach(function(c) {
        if (c !== card) closeCard(c);
      });
      if (wasActive) {
        closeCard(card);
      } else {
        card.classList.add('active');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Proven benefits",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<strong>Proven Benefits.</strong> Backed by Science."
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Your body deserves more than empty claims. <strong>Resilia® delivers real, measurable results</strong> using ingredients with decades of clinical research."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Heading highlight color",
      "default": "#009370",
      "info": "Color for bold text in heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f1f3ea"
    },
    {
      "type": "header",
      "content": "Mobile CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Try Risk-Free Today"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "cta_note",
      "label": "Note text",
      "default": "30-day money back guarantee"
    },
    {
      "type": "text",
      "id": "cta_note_icon_name",
      "label": "Note icon name",
      "default": "verified_user",
      "info": "Google icon name (fonts.google.com/icons)"
    },
    {
      "type": "image_picker",
      "id": "cta_note_icon",
      "label": "Note icon image",
      "info": "Overrides Google icon if set"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Short description"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Expanded answer",
          "default": "Detailed explanation of this benefit that appears when the card is expanded."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Proven benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Immunity",
            "description": "Strengthen your body",
            "answer": "Oregano oil is packed with carvacrol, a powerful compound shown to fight off bacteria and viruses—supporting your immune system every single day."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Inflammation",
            "description": "Soothe it at the source",
            "answer": "Black seed oil helps calm inflammation, restore gut balance, and reduce bloating—so you feel lighter, more regular, and at ease."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Digestion",
            "description": "Gut health without bloat",
            "answer": "Both oregano and black seed oils contain antioxidants that help reduce chronic inflammation, promoting long-term joint, gut, and immune health."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Clarity",
            "description": "Feel focused, not foggy",
            "answer": "By supporting gut and immune balance, Resilia® helps you feel sharper and more energized—without relying on caffeine or stimulants."
          }
        }
      ]
    }
  ]
}
{% endschema %}
