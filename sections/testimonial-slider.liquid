{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign ticker_images = section.blocks | where: "type", "ticker_image" -%}
{%- assign reviews = section.blocks | where: "type", "review" -%}

<style>
  .testimonial-section {
    width: 100%;
  }

  testimonial-reviews-slider {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  /* Header */
  .ts-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .ts-stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    margin-bottom: 0.8rem;
  }

  .ts-stars svg {
    width: 18px;
    height: 18px;
    fill: var(--ts-star-color, #009370);
  }

  .ts-heading {
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 0.5rem;
  }

  .ts-heading strong {
    color: var(--ts-highlight, #009370);
  }

  .ts-subheading {
    font-size: 1.4rem;
    color: rgba(43, 43, 43, 0.7);
    margin: 0;
  }

  /* Ticker */
  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ts-ticker {
    overflow: hidden;
    width: 100%;
    margin: 1.5rem 0;
  }

  .ts-ticker__track {
    display: flex;
    gap: 10px;
    width: max-content;
    animation: ticker-scroll var(--ts-ticker-speed, 30s) linear infinite;
  }

  .ts-ticker:hover .ts-ticker__track {
    animation-play-state: paused;
  }

  .ts-ticker__img {
    width: 100px;
    height: 100px;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
    display: block;
  }

  .ts-ticker__placeholder {
    width: 100px;
    height: 100px;
    border-radius: 12px;
    flex-shrink: 0;
    background: #e5e5e5;
  }

  .ts-ticker__placeholder svg {
    width: 100%;
    height: 100%;
    border-radius: 12px;
  }

  /* Review cards slider */
  .ts-reviews__track {
    display: flex;
    transition: transform 0.35s ease;
  }

  .ts-review-slide {
    box-sizing: border-box;
    padding: 0 0.75rem;
    flex: 0 0 100%;
  }

  .ts-review-card {
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    background: var(--ts-card-bg, #ffffff);
  }

  .ts-review__rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .ts-review__rating-num {
    font-size: 1.4rem;
    font-weight: 600;
    color: #2b2b2b;
  }

  .ts-review__rating-stars {
    display: inline-flex;
    gap: 1px;
  }

  .ts-review__rating-stars svg {
    width: 14px;
    height: 14px;
    fill: var(--ts-star-color, #009370);
  }

  .ts-review__quote {
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.8rem;
    color: #2b2b2b;
  }

  .ts-review__details {
    font-size: 1.3rem;
    line-height: 1.55;
    color: rgba(43, 43, 43, 0.8);
    margin-bottom: 1.2rem;
  }

  .ts-review__author {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 0.5rem;
  }

  .ts-review__auth-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ts-review__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .ts-review__name {
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #2b2b2b;
  }

  .ts-review__verified {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--ts-verified, #009370);
    letter-spacing: 0.03em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ts-review__verified svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .ts-review__tags {
    display: flex;
    gap: 0.5rem;
  }

  .ts-review__tag {
    flex: 1;
    text-align: center;
    border: 1.5px solid var(--ts-tag, #009370);
    color: var(--ts-tag, #009370);
    background: var(--ts-tag-bg, transparent);
    border-radius: 20px;
    padding: 0.5rem 0.5rem;
    font-size: 1.2rem;
    font-weight: 500;
    white-space: nowrap;
  }

  /* Controls */
  .ts-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .ts-dots {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .ts-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.25s;
  }

  .ts-dot.active {
    background: var(--ts-highlight, #009370);
    width: 24px;
    border-radius: 4px;
  }

  .ts-arrow {
    background: none;
    border: 1px solid #ccc;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.2s, opacity 0.2s;
    flex-shrink: 0;
  }

  .ts-arrow:hover {
    border-color: #999;
  }

  .ts-arrow.disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }

  .ts-arrow svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Desktop */
  @media screen and (min-width: 750px) {
    .ts-heading {
      font-size: 3.4rem;
    }
    .ts-review-slide {
      flex: 0 0 calc(100% / 3);
    }
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .ts-heading {
      font-size: 2.2rem;
    }
    .ts-ticker__img,
    .ts-ticker__placeholder,
    .ts-ticker__placeholder svg {
      width: 80px;
      height: 80px;
    }
    .ts-review__author {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }
  }
</style>

<div
  class="section-{{ section.id }}-padding testimonial-section"
  style="
    --ts-highlight: {{ section.settings.highlight_color }};
    --ts-star-color: {{ section.settings.star_color }};
    --ts-verified: {{ section.settings.verified_color }};
    --ts-tag: {{ section.settings.tag_color }};
    {% if section.settings.tag_bg_color != blank %}--ts-tag-bg: {{ section.settings.tag_bg_color }};{% endif %}
    --ts-ticker-speed: {{ section.settings.ticker_speed }}s;
    {% if section.settings.section_bg_color != blank %}background: {{ section.settings.section_bg_color }};{% endif %}
  "
>
  <div class="page-width">
    <div class="ts-header">
      <div class="ts-stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {%- endfor -%}
      </div>
      {%- if section.settings.heading != blank -%}
        <h2 class="ts-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="ts-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- if ticker_images.size > 0 -%}
    <div class="ts-ticker">
      <div class="ts-ticker__track">
        {%- for block in ticker_images -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'ts-ticker__img', widths: '100,200,300' }}
          {%- else -%}
            <div class="ts-ticker__placeholder">{{ 'product-apparel-1' | placeholder_svg_tag }}</div>
          {%- endif -%}
        {%- endfor -%}
        {%- for block in ticker_images -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'ts-ticker__img', widths: '100,200,300' }}
          {%- else -%}
            <div class="ts-ticker__placeholder">{{ 'product-apparel-1' | placeholder_svg_tag }}</div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if reviews.size > 0 -%}
    <div class="page-width">
      <testimonial-reviews-slider>
        <div class="ts-reviews__track">
          {%- for block in reviews -%}
            <div class="ts-review-slide" {{ block.shopify_attributes }}>
              <div class="ts-review-card" {% if block.settings.card_bg_color != blank %}style="--ts-card-bg: {{ block.settings.card_bg_color }};"{% endif %}>
                <div>
                  <div class="ts-review__rating">
                    <span class="ts-review__rating-num">{{ block.settings.rating }}</span>
                    <div class="ts-review__rating-stars">
                      {%- for i in (1..5) -%}
                        <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      {%- endfor -%}
                    </div>
                  </div>
                  {%- if block.settings.quote != blank -%}
                    <div class="ts-review__quote">{{ block.settings.quote }}</div>
                  {%- endif -%}
                  {%- if block.settings.details != blank -%}
                    <div class="ts-review__details">{{ block.settings.details }}</div>
                  {%- endif -%}
                </div>
                <div>
                  <div class="ts-review__author">
                    <div class="ts-review__auth-info">
                      {%- if block.settings.author_image != blank -%}
                        {{ block.settings.author_image | image_url: width: 80 | image_tag: loading: 'lazy', class: 'ts-review__avatar', widths: '56,80' }}
                      {%- endif -%}
                      {%- if block.settings.author_name != blank -%}
                        <span class="ts-review__name">{{ block.settings.author_name }}</span>
                      {%- endif -%}
                    </div>
                    <span class="ts-review__verified">
                      <svg viewBox="0 0 12 12" fill="none">
                        <path d="M11.09 4.93c.08-.19.09-.4.03-.6a.93.93 0 00-.37-.46l-.96-.58a.18.18 0 01-.06-.13l-.25-1.09a.93.93 0 00-.9-.65l-1.12.1a.18.18 0 01-.07-.02L6.55.83a.93.93 0 00-1.11 0L4.6 1.57a.18.18 0 01-.07.02l-1.12-.1a.93.93 0 00-.9.65L2.26 3.24a.18.18 0 01-.06.13l-.96.57a.93.93 0 00-.33 1.06l.44 1.03a.18.18 0 010 .07L.91 7.07a.93.93 0 00.33 1.06l.96.57a.18.18 0 01.06.13l.25 1.09c.05.2.17.38.33.51.16.12.37.18.57.16l1.12-.1a.18.18 0 01.07.02l.84.74a.93.93 0 001.11 0l.84-.74a.18.18 0 01.07-.02l1.12.1a.93.93 0 00.9-.66l.25-1.09a.18.18 0 01.06-.13l.96-.57a.93.93 0 00.34-1.06l-.44-1.03a.18.18 0 010-.07l.44-1.03z" fill="currentColor"/>
                        <path d="M7.71 4.47L5.45 6.78l-1.21-.87a.37.37 0 00-.52.52l1.47 1.05a.37.37 0 00.49-.09l2.48-2.54a.37.37 0 00-.45-.38z" fill="#fff"/>
                      </svg>
                      VERIFIED CUSTOMER
                    </span>
                  </div>
                  {%- if block.settings.tag_1 != blank or block.settings.tag_2 != blank -%}
                    <div class="ts-review__tags">
                      {%- if block.settings.tag_1 != blank -%}
                        <span class="ts-review__tag">{{ block.settings.tag_1 }}</span>
                      {%- endif -%}
                      {%- if block.settings.tag_2 != blank -%}
                        <span class="ts-review__tag">{{ block.settings.tag_2 }}</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </testimonial-reviews-slider>

      {%- if reviews.size > 1 -%}
        <div class="ts-controls">
          <button class="ts-arrow ts-arrow--prev disabled" aria-label="Previous">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <div class="ts-dots"></div>
          <button class="ts-arrow ts-arrow--next" aria-label="Next">
            <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<script>
  if (!customElements.get('testimonial-reviews-slider')) {
    class TestimonialReviewsSlider extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ts-reviews__track');
        this.slides = this.track ? [...this.track.children] : [];
        this.total = this.slides.length;
        if (this.total <= 1) return;

        const section = this.closest('.testimonial-section');
        this.dotsContainer = section ? section.querySelector('.ts-dots') : null;
        this.prevBtn = section ? section.querySelector('.ts-arrow--prev') : null;
        this.nextBtn = section ? section.querySelector('.ts-arrow--next') : null;

        this.prevBtn?.addEventListener('click', () => this.goTo(this.currentIndex - 1));
        this.nextBtn?.addEventListener('click', () => this.goTo(this.currentIndex + 1));

        let startX = 0, diff = 0;
        this.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
        this.addEventListener('touchmove', (e) => { diff = e.touches[0].clientX - startX; }, { passive: true });
        this.addEventListener('touchend', () => {
          if (Math.abs(diff) > 50) this.goTo(this.currentIndex + (diff < 0 ? 1 : -1));
          diff = 0;
        });

        this._onResize = () => this.updateLayout();
        window.addEventListener('resize', this._onResize);
        this.updateLayout();
      }

      get perView() {
        return window.innerWidth >= 750 ? 3 : 1;
      }

      get maxIndex() {
        return Math.max(0, this.total - this.perView);
      }

      updateLayout() {
        const pv = this.perView;
        this.slides.forEach(s => { s.style.flex = `0 0 calc(100% / ${pv})`; });
        if (this.currentIndex > this.maxIndex) this.currentIndex = this.maxIndex;
        this.buildDots();
        this.applyPosition();
        this.updateArrows();
      }

      buildDots() {
        if (!this.dotsContainer) return;
        const count = this.maxIndex + 1;
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < count; i++) {
          const dot = document.createElement('button');
          dot.className = 'ts-dot' + (i === this.currentIndex ? ' active' : '');
          dot.setAttribute('aria-label', `Slide ${i + 1}`);
          dot.addEventListener('click', () => this.goTo(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      goTo(index) {
        if (index < 0) index = 0;
        if (index > this.maxIndex) index = this.maxIndex;
        this.currentIndex = index;
        this.applyPosition();
        this.updateArrows();
        this.dotsContainer?.querySelectorAll('.ts-dot').forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
      }

      applyPosition() {
        const pct = (100 / this.perView) * this.currentIndex;
        this.track.style.transform = `translateX(-${pct}%)`;
      }

      updateArrows() {
        this.prevBtn?.classList.toggle('disabled', this.currentIndex === 0);
        this.nextBtn?.classList.toggle('disabled', this.currentIndex >= this.maxIndex);
      }

      disconnectedCallback() {
        window.removeEventListener('resize', this._onResize);
      }
    }

    customElements.define('testimonial-reviews-slider', TestimonialReviewsSlider);
  }
</script>

