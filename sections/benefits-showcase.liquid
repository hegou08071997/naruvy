{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign needs_material_font = false -%}
{%- for block in section.blocks -%}
  {%- if block.settings.custom_icon == blank and block.settings.icon_name != blank -%}
    {%- assign needs_material_font = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}
{%- if needs_material_font -%}
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet">
{%- endif -%}

<style>
  .benefits-showcase {
    width: 100%;
    background: var(--bs-bg, #1a3c2a);
    color: var(--bs-text, #ffffff);
    overflow: hidden;
  }

  .bs-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .bs-heading {
    font-size: var(--bs-heading-size, 3.6rem);
    line-height: 1.2;
    margin: 0 0 0.8rem;
    color: var(--bs-text, #ffffff);
  }

  .bs-heading strong {
    color: var(--bs-highlight, #ffffff);
  }

  .bs-subheading {
    font-size: var(--bs-sub-size, 1.5rem);
    margin: 0;
    color: var(--bs-sub-color, var(--bs-text, #ffffff));
  }

  .bs-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  /* Benefits grid */
  .bs-benefits {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem 3rem;
  }

  .bs-benefit {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .bs-benefit__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bs-benefit__icon .material-symbols-outlined {
    font-size: 42px;
    color: var(--bs-text, #ffffff);
    line-height: 1;
  }

  .bs-benefit__icon img {
    width: 42px;
    height: 42px;
    object-fit: contain;
  }

  .bs-benefit__title {
    font-size: var(--bs-benefit-size, 1.6rem);
    font-weight: 600;
    line-height: 1.3;
    color: var(--bs-text, #ffffff);
    margin: 0;
  }

  /* Product image */
  .bs-image {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .bs-image__circle {
    position: absolute;
    width: 80%;
    aspect-ratio: 1 / 1;
    border: 2px dashed rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    pointer-events: none;
  }

  .bs-image__img {
    position: relative;
    max-width: 75%;
    height: auto;
    display: block;
  }

  .bs-image__placeholder {
    position: relative;
    width: 75%;
  }

  .bs-image__placeholder svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .bs-header {
      margin-bottom: 2rem;
    }
    .bs-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .bs-benefits {
      gap: 2rem 1.5rem;
    }
    .bs-benefit__icon .material-symbols-outlined {
      font-size: 36px;
    }
    .bs-benefit__icon img {
      width: 36px;
      height: 36px;
    }
    .bs-image__img,
    .bs-image__placeholder {
      max-width: 60%;
      width: 60%;
    }
  }
</style>

<div
  class="section-{{ section.id }}-padding benefits-showcase"
  style="
    --bs-bg: {{ section.settings.bg_color }};
    --bs-text: {{ section.settings.text_color }};
    --bs-highlight: {{ section.settings.highlight_color }};
    {% if section.settings.subheading_color != blank %}--bs-sub-color: {{ section.settings.subheading_color }};{% endif %}
    --bs-heading-size: {{ section.settings.heading_size }}rem;
    --bs-sub-size: {{ section.settings.subheading_size }}rem;
    --bs-benefit-size: {{ section.settings.benefit_size }}rem;
  "
>
  <div class="page-width">
    <div class="bs-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bs-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="bs-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="bs-layout">
      <div class="bs-benefits">
        {%- for block in section.blocks -%}
          <div class="bs-benefit" {{ block.shopify_attributes }}>
            <div class="bs-benefit__icon">
              {%- if block.settings.custom_icon != blank -%}
                {{ block.settings.custom_icon | image_url: width: 100 | image_tag: widths: '42,84,100', loading: 'lazy' }}
              {%- elsif block.settings.icon_name != blank -%}
                <span class="material-symbols-outlined">{{ block.settings.icon_name }}</span>
              {%- endif -%}
            </div>
            {%- if block.settings.title != blank -%}
              <p class="bs-benefit__title">{{ block.settings.title }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <div class="bs-image">
        <div class="bs-image__circle"></div>
        {%- if section.settings.product_image != blank -%}
          {{
            section.settings.product_image
            | image_url: width: 900
            | image_tag: loading: 'lazy', class: 'bs-image__img', widths: '400,600,900', sizes: '(min-width: 750px) 40vw, 60vw'
          }}
        {%- else -%}
          <div class="bs-image__placeholder">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Benefits showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Feel Better. <strong>Every Day.</strong>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "From fewer sick days to smoother digestion, here's what makes [BRAND] different."
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#9F3F3F"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Heading highlight color",
      "default": "#ffffff",
      "info": "Color for bold text in heading"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading text color",
      "info": "Defaults to main text color if not set"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 2,
      "max": 5,
      "step": 0.2,
      "default": 3.6,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading font size",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.5,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "benefit_size",
      "label": "Benefit title font size",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.6,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "icon_name",
          "label": "Google icon name",
          "default": "check_circle",
          "info": "Browse icons at fonts.google.com/icons"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon image",
          "info": "Overrides Google icon if set"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits showcase",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon_name": "health_and_safety",
            "title": "Daily Immune Defense"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_name": "science",
            "title": "Gut Health & Digestion Support"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_name": "bolt",
            "title": "Boosts Energy & Clarity"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_name": "spa",
            "title": "Soothes Inflammation"
          }
        }
      ]
    }
  ]
}
{% endschema %}
