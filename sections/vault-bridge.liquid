{%- if section.settings.show_top_divider -%}
  <div class="vopt-divider"><hr></div>
{%- endif -%}

<section class="vopt-bridge vopt-wrap">
  {%- if section.settings.eyebrow != blank -%}
    <p class="vopt-eyebrow">{{ section.settings.eyebrow | escape }}</p>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 class="vopt-bridge-h">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}
  {%- if section.settings.subhead != blank -%}
    <p class="vopt-bridge-sub">{{ section.settings.subhead | escape }}</p>
  {%- endif -%}

  <div class="vopt-bridge-cols">
    <div class="vopt-bridge-side vopt-bridge-side--pain">
      {%- if section.settings.pain_title != blank -%}<h4>{{ section.settings.pain_title | escape }}</h4>{%- endif -%}
      <ul>
        {%- assign pain_items = section.settings.pain_list | newline_to_br | split: '<br />' -%}
        {%- for item in pain_items -%}
          {%- assign t = item | strip -%}
          {%- if t != blank -%}<li>{{ t | escape }}</li>{%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <div class="vopt-bridge-arrow" aria-hidden="true">&rarr;</div>

    <div class="vopt-bridge-side vopt-bridge-side--gain">
      {%- if section.settings.gain_title != blank -%}<h4>{{ section.settings.gain_title | escape }}</h4>{%- endif -%}
      <ul>
        {%- assign gain_items = section.settings.gain_list | newline_to_br | split: '<br />' -%}
        {%- for item in gain_items -%}
          {%- assign t = item | strip -%}
          {%- if t != blank -%}<li>{{ t | escape }}</li>{%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>

  {%- if section.settings.foot != blank -%}
    <p class="vopt-bridge-foot">{{ section.settings.foot | escape }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Vault Bridge",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show divider above section",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The problem with scattered learning"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "STOP PIECING TOGETHER RANDOM GUITAR ADVICE"
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Supporting copy",
      "default": "You can spend years bouncing between clips, tabs, and half-explained tricks. Or you can grab one clean stash of Greg's chicken pickin', outside playing, tone, chord vocabulary, blues ideas, and clinic breakdowns."
    },
    {
      "type": "header",
      "content": "Pain column"
    },
    {
      "type": "text",
      "id": "pain_title",
      "label": "Pain column title",
      "default": "The scattered way"
    },
    {
      "type": "textarea",
      "id": "pain_list",
      "label": "Pain points (one per line)",
      "default": "Random licks from fifty different videos\nTabs that never quite line up\nHalf-explained tricks with no context\nNothing that connects into real playing"
    },
    {
      "type": "header",
      "content": "Gain column"
    },
    {
      "type": "text",
      "id": "gain_title",
      "label": "Gain column title",
      "default": "The Vault way"
    },
    {
      "type": "textarea",
      "id": "gain_list",
      "label": "Gains (one per line)",
      "default": "Eight full lessons in one place\nClinics, breakdowns, and technique\nThe exact picking, voicings, and settings\nA 12-page PDF that ties it together"
    },
    {
      "type": "text",
      "id": "foot",
      "label": "Transition line",
      "default": "Here’s what’s inside the free stash."
    }
  ],
  "presets": [{ "name": "Vault Bridge" }]
}
{% endschema %}
