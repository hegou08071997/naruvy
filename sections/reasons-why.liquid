<style>
  .rw-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
    text-align: center;
  }
  @media screen and (min-width: 750px) {
    .rw-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .rw-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 50px;
  }
  @media screen and (max-width: 749px) {
    .rw-container { padding: 0 20px; }
  }

  /* Badge heading */
  .rw-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.badge_bg_color }};
    color: {{ section.settings.badge_text_color }};
    font-size: {{ section.settings.badge_font_size }}px;
    font-weight: 500;
    line-height: 1;
    padding: 10px 20px;
    border-radius: 10px;
    margin-bottom: 14px;
  }

  /* Subheading */
  .rw-subheading {
    font-size: {{ section.settings.subheading_font_size }}px;
    line-height: 1;
    margin: 0 0 40px;
    color: {{ section.settings.text_color }};
  }
  @media screen and (max-width: 749px) {
    .rw-subheading {
      font-size: calc({{ section.settings.subheading_font_size }}px * 0.7);
      line-height: 1.3;
      margin-bottom: 25px;
    }
  }

  /* Cards grid */
  .rw-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: {{ section.settings.card_gap }}px;
  }
  @media screen and (max-width: 749px) {
    .rw-grid {
      gap: 12px;
    }
  }

  /* Card */
  .rw-card {
    background-color: {{ section.settings.card_bg_color }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    position: relative;
    width: {{ section.settings.card_width }}px;
    min-height: {{ section.settings.card_height }}px;
    padding: 22px 21px 17px;
    text-align: center;
  }
  @media screen and (max-width: 749px) {
    .rw-card {
      width: calc(50% - 6px);
      min-height: 300px;
      padding: 15px 12px 12px;
    }
  }
  @media screen and (max-width: 449px) {
    .rw-card {
      width: 100%;
      min-height: auto;
    }
  }

  /* Card front (image + label + heading) */
  .rw-card__front {
    backface-visibility: hidden;
    transition: opacity 0.5s;
  }
  .rw-card.is-flipped .rw-card__front {
    opacity: 0;
    pointer-events: none;
  }

  .rw-card__image {
    width: 100%;
    border-radius: 4px;
    display: block;
    margin-bottom: 0;
  }

  .rw-card__label {
    display: inline-block;
    background-color: {{ section.settings.label_bg_color }};
    color: {{ section.settings.label_text_color }};
    font-size: {{ section.settings.label_font_size }}px;
    font-weight: 500;
    line-height: 1.4;
    padding: 2px 8px;
    border-radius: 5px;
    margin: 19px 0 7px;
  }

  .rw-card__heading {
    font-size: {{ section.settings.card_heading_font_size }}px;
    font-weight: 400;
    line-height: 1.25;
    margin: 0 0 7px;
    color: {{ section.settings.card_text_color }};
  }

  /* Card back (details) */
  .rw-card__details {
    position: absolute;
    inset: 0;
    padding: 22px 21px 17px;
    font-size: 16px;
    line-height: 1.3;
    color: {{ section.settings.card_text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s;
    background-color: {{ section.settings.card_bg_color }};
  }
  .rw-card.is-flipped .rw-card__details {
    opacity: 1;
    pointer-events: auto;
  }
  .rw-card__details p {
    margin: 0 0 10px;
  }
  .rw-card__details p:last-child {
    margin-bottom: 0;
  }

  /* Toggle button */
  .rw-card__toggle {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 11px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .rw-card__toggle-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 27px;
    height: 27px;
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: 50%;
    background: {{ section.settings.card_bg_color }};
  }
  .rw-card__toggle-icon svg {
    fill: none;
  }
  .rw-card .rw-toggle-minus { display: none; }
  .rw-card.is-flipped .rw-toggle-plus { display: none; }
  .rw-card.is-flipped .rw-toggle-minus { display: inline-flex; }

  /* CTA area */
  .rw-cta {
    margin-top: {{ section.settings.cta_margin_top }}px;
    text-align: center;
  }
  .rw-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.cta_bg_color }};
    color: {{ section.settings.cta_text_color }};
    font-size: {{ section.settings.cta_font_size }}px;
    font-weight: 500;
    line-height: 1;
    padding: 17px 40px;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.3s;
    max-width: 336px;
  }
  .rw-cta__button:hover {
    opacity: 0.85;
  }
  .rw-cta__note {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    font-size: 17px;
    line-height: 1.25;
    margin-top: 12px;
    color: {{ section.settings.text_color }};
  }
  .rw-cta__note img {
    width: 17px;
    height: 17px;
    display: block;
    object-fit: contain;
  }
</style>

<section class="rw-section" id="reasons-why-{{ section.id }}">
  <div class="rw-container">
    {%- if section.settings.badge_text != blank -%}
      <div class="rw-badge">{{ section.settings.badge_text }}</div>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <h2 class="rw-subheading">{{ section.settings.subheading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="rw-grid">
        {%- for block in section.blocks -%}
          <div class="rw-card" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <div class="rw-card__front">
              {%- if block.settings.image != blank -%}
                <img
                  class="rw-card__image"
                  src="{{ block.settings.image | image_url: width: 500 }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  width="auto"
                  height="auto"
                >
              {%- else -%}
                {{ 'product-apparel-1' | placeholder_svg_tag: 'rw-card__image placeholder-svg' }}
              {%- endif -%}
              {%- if block.settings.label != blank -%}
                <div class="rw-card__label">{{ block.settings.label }}</div>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="rw-card__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
            </div>

            <div class="rw-card__details">
              <div>{{ block.settings.details }}</div>
            </div>

            {%- if block.settings.details != blank -%}
              <button class="rw-card__toggle" aria-expanded="false" aria-label="Toggle details">
                <span class="rw-card__toggle-icon rw-toggle-plus">
                  <svg width="12" height="12" viewBox="0 0 12 12" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5.72069 11.033V5.96898H0.656637V5.38515H5.72069V0.321103H6.30451V5.38515H11.3686V5.96898H6.30451V11.033H5.72069Z" fill="black"/>
                  </svg>
                </span>
                <span class="rw-card__toggle-icon rw-toggle-minus">
                  <svg width="8" height="1" viewBox="0 0 8 1" xmlns="http://www.w3.org/2000/svg">
                    <path d="M7.97719 0.0678547V0.65168H0.920525V0.0678547H7.97719Z" fill="black"/>
                  </svg>
                </span>
              </button>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank or section.settings.guarantee_text != blank -%}
      <div class="rw-cta">
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_url }}" class="rw-cta__button">
            {{ section.settings.cta_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.guarantee_text != blank -%}
          <p class="rw-cta__note">
            {%- if section.settings.guarantee_icon != blank -%}
              <img src="{{ section.settings.guarantee_icon | image_url: width: 40 }}" alt="" loading="lazy">
            {%- endif -%}
            {{ section.settings.guarantee_text }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('reasons-why-{{ section.id }}');
    if (!section) return;
    section.addEventListener('click', function(e) {
      var btn = e.target.closest('.rw-card__toggle');
      if (!btn) return;
      var card = btn.closest('.rw-card');
      if (!card) return;
      var isFlipped = card.classList.toggle('is-flipped');
      btn.setAttribute('aria-expanded', isFlipped ? 'true' : 'false');
    });
  })();
</script>

