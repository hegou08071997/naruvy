{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .usp-bar-wrapper--{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  .usp-bar-inner--{{ section.id }} {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: {{ section.settings.item_gap }}px;
  }

  .usp-item--{{ section.id }} {
    border: 1.3px solid {{ section.settings.border_color }};
    padding: {{ section.settings.item_padding_vertical }}px {{ section.settings.item_padding_horizontal }}px;
    border-radius: 6.9px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: {{ section.settings.font_size }}px;
    font-weight: 500;
    background: transparent;
    flex: 1;
    text-align: center;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .usp-item__icon--{{ section.id }} {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
  }

  .usp-item__icon--{{ section.id }} img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  @media (max-width: 749px) {
    .usp-bar-inner--{{ section.id }} {
      gap: {{ section.settings.item_gap | times: 0.6 | round: 0 }}px;
    }

    .usp-item--{{ section.id }} {
      font-size: {{ section.settings.font_size | minus: 3 }}px;
      padding: {{ section.settings.item_padding_vertical | times: 0.7 | round: 0 }}px {{ section.settings.item_padding_horizontal | times: 0.5 | round: 0 }}px;
      gap: 5px;
    }

    .usp-item__icon--{{ section.id }} {
      width: 16px;
      height: 16px;
    }
  }
</style>

<div class="usp-bar-wrapper--{{ section.id }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="usp-bar-inner--{{ section.id }}">
      {%- assign usp_texts = 'text_1,text_2,text_3' | split: ',' -%}
      {%- assign usp_icons = 'icon_1,icon_2,icon_3' | split: ',' -%}
      {%- for i in (0..2) -%}
        {%- assign txt = section.settings[usp_texts[i]] -%}
        {%- assign icon = section.settings[usp_icons[i]] -%}
        {%- if txt != blank -%}
          <div class="usp-item--{{ section.id }}">
            {%- if icon != blank -%}
              <span class="usp-item__icon--{{ section.id }}">
                <img
                  src="{{ icon | image_url: width: 48 }}"
                  alt=""
                  width="22"
                  height="22"
                  loading="eager"
                >
              </span>
            {%- endif -%}
            <span>{{ txt }}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "USP bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#095946"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "item_gap",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Gap between items",
      "default": 10
    },
    {
      "type": "range",
      "id": "item_padding_vertical",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Item padding (vertical)",
      "default": 7
    },
    {
      "type": "range",
      "id": "item_padding_horizontal",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Item padding (horizontal)",
      "default": 8
    },
    {
      "type": "header",
      "content": "Item 1"
    },
    {
      "type": "image_picker",
      "id": "icon_1",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text",
      "default": "CLINICALLY STUDIED INGREDIENTS†"
    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "image_picker",
      "id": "icon_2",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text",
      "default": "THIRD PARTY TESTED"
    },
    {
      "type": "header",
      "content": "Item 3"
    },
    {
      "type": "image_picker",
      "id": "icon_3",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text",
      "default": "CLEAN FORMULA"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "USP bar"
    }
  ]
}
{% endschema %}
