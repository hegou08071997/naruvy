{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .hero-banner-wrapper--{{ section.id }} {
    background: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  .hero-banner-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
  }

  .hero-banner-left {
    flex: 1 1 45%;
    text-align: center;
  }

  .hero-banner-left img {
    height: auto;
    max-width: 476px;
    margin: 0 auto;
    width: 100%;
    display: block;
  }

  .hero-banner-right {
    flex: 1 1 36%;
    padding: 0;
    text-align: center;
  }

  .hero-banner-badge--{{ section.id }} {
    width: fit-content;
    background-color: {{ section.settings.badge_bg_color }};
    color: {{ section.settings.badge_text_color }};
    border-radius: 5px;
    font-weight: 500;
    font-size: {{ section.settings.badge_font_size }}px;
    padding: 16px 24px;
    margin: 0 auto 12px;
    text-transform: uppercase;
  }

  .hero-stars--{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: 15.81px;
    margin-bottom: 21.32px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    line-height: 23.71px;
    gap: 10.54px;
    justify-content: center;
  }

  .hero-stars--{{ section.id }} .hero-stars__icons {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .hero-stars--{{ section.id }} .hero-stars__icons svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .hero-stars--{{ section.id }} strong {
    font-weight: 500;
  }

  h2.hero-headline--{{ section.id }} {
    font-weight: 400;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.09;
    letter-spacing: 0;
    text-align: center;
    margin-bottom: 18.18px;
    color: {{ section.settings.text_color }};
    margin-top: 0;
  }

  h2.hero-headline--{{ section.id }} strong {
    font-weight: 500;
  }

  .hero-subheadline--{{ section.id }} {
    font-weight: 400;
    font-size: 16.96px;
    line-height: 19.39px;
    letter-spacing: 0;
    text-align: center;
    max-width: 334px;
    margin: 0 auto 18.18px;
    color: {{ section.settings.text_color }};
  }

  .hero-button--{{ section.id }} {
    max-width: 336px;
    border-radius: 6.06px;
    padding: 16.46px;
    background: {{ section.settings.cta_bg_color }};
    font-weight: 500;
    font-size: 19.39px;
    line-height: 19.39px;
    letter-spacing: 0;
    text-align: center;
    color: {{ section.settings.cta_text_color }};
    display: inline-flex;
    height: 54.5px;
    width: 100%;
    justify-content: center;
    align-items: center;
    margin-bottom: 10px;
    transition: 0.5s;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .hero-button--{{ section.id }}:hover {
    box-shadow: 0 0 0px 2px {{ section.settings.cta_bg_color }} inset;
    background: transparent;
    color: {{ section.settings.cta_bg_color }};
  }

  .hero-guarantee--{{ section.id }} {
    font-weight: 400;
    font-size: 16.96px;
    line-height: 21.33px;
    letter-spacing: 0;
    text-align: center;
    display: flex;
    align-items: center;
    gap: 4px;
    justify-content: center;
    color: {{ section.settings.text_color }};
  }

  .hero-guarantee--{{ section.id }} img {
    max-width: 17px;
    height: auto;
  }

  @media (max-width: 749px) {
    .hero-banner-inner {
      flex-direction: column-reverse;
    }

    .hero-banner-right {
      padding-top: 23.5px;
    }

    .hero-stars--{{ section.id }} .hero-stars__icons svg {
      width: 14px;
      height: 14px;
    }

    .hero-stars--{{ section.id }} {
      font-size: 13.04px;
      margin-bottom: 17.05px;
      line-height: 19.57px;
      gap: 8.7px;
    }

    h2.hero-headline--{{ section.id }} {
      font-size: {{ section.settings.heading_size | times: 0.825 | round: 0 }}px;
      line-height: 1.09;
      margin-bottom: 15px;
      max-width: 330px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-subheadline--{{ section.id }} {
      font-size: 14px;
      line-height: 16px;
      max-width: 277px;
      margin: 0 auto 15px;
    }

    .hero-button--{{ section.id }} {
      max-width: 277px;
      border-radius: 5px;
      font-size: 16px;
      height: 45px;
      margin-bottom: 8px;
    }

    .hero-guarantee--{{ section.id }} {
      font-size: 14px;
      line-height: 17.6px;
      gap: 3.2px;
    }

    .hero-guarantee--{{ section.id }} img {
      max-width: 14px;
    }

    {%- if section.settings.mobile_bg_image != blank -%}
      .hero-banner-wrapper--{{ section.id }} {
        background-image: url({{ section.settings.mobile_bg_image | image_url: width: 1200 }});
        background-size: cover;
        background-repeat: no-repeat;
        background-position: bottom center;
      }
      .hero-banner-wrapper--{{ section.id }} .hero-banner-left {
        opacity: 0;
      }
    {%- endif -%}
  }
</style>

<div class="hero-banner-wrapper--{{ section.id }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="hero-banner-inner">
      <div class="hero-banner-left">
        {%- if section.settings.desktop_image != blank -%}
          <img
            src="{{ section.settings.desktop_image | image_url: width: 952 }}"
            alt="{{ section.settings.desktop_image.alt | escape }}"
            width="{{ section.settings.desktop_image.width }}"
            height="{{ section.settings.desktop_image.height }}"
            loading="eager"
            fetchpriority="high"
          >
        {%- endif -%}
      </div>

      <div class="hero-banner-right">
        {%- if section.settings.badge_text != blank -%}
          <div class="hero-banner-badge--{{ section.id }}">
            {{ section.settings.badge_text }}
          </div>
        {%- endif -%}

        {%- if section.settings.show_stars -%}
          {%- assign hero_rating_floor = section.settings.star_rating | floor -%}
          {%- assign hero_rating_remainder = section.settings.star_rating | minus: hero_rating_floor -%}
          {%- assign hero_partial_index = hero_rating_floor | plus: 1 -%}
          {%- assign hero_partial_pct = hero_rating_remainder | times: 100 -%}
          <div class="hero-stars--{{ section.id }}">
            <div class="hero-stars__icons" aria-hidden="true">
              {%- for i in (1..5) -%}
                {%- if i <= hero_rating_floor -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512">
                    <path fill="{{ section.settings.star_color }}" d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
                  </svg>
                {%- elsif i == hero_partial_index and hero_rating_remainder > 0 -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512">
                    <defs><linearGradient id="hero-star-grad-{{ section.id }}"><stop offset="{{ hero_partial_pct }}%" stop-color="{{ section.settings.star_color }}"/><stop offset="{{ hero_partial_pct }}%" stop-color="{{ section.settings.star_empty_color }}"/></linearGradient></defs><path fill="url(#hero-star-grad-{{ section.id }})" d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
                  </svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512">
                    <path fill="{{ section.settings.star_empty_color }}" d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if section.settings.stars_text != blank -%}
              <span>{{ section.settings.stars_text }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="hero-headline--{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheadline != blank -%}
          <div class="hero-subheadline--{{ section.id }}">{{ section.settings.subheadline }}</div>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <a href="#" class="hero-button--{{ section.id }}" data-hero-btn>{{ section.settings.cta_text }}</a>
        {%- endif -%}

        {%- if section.settings.guarantee_text != blank -%}
          <div class="hero-guarantee--{{ section.id }}">
            {%- if section.settings.guarantee_icon != blank -%}
              <img
                src="{{ section.settings.guarantee_icon | image_url: width: 34 }}"
                alt=""
                width="17"
                height="auto"
                loading="eager"
              >
            {%- else -%}
              <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2.7179 3.96923V7.40687C2.71738 11.0519 5.00315 14.3807 8.4064 15.6896C8.68102 15.7954 8.97001 15.8477 9.25901 15.8477C9.548 15.8477 9.83699 15.7949 10.1121 15.6896L10.6224 15.493C13.7679 14.2832 15.8006 11.2403 15.8001 7.74155V3.96923C15.8001 3.68691 15.5768 3.4549 15.295 3.44412C13.4055 3.37071 11.4791 2.6259 9.56905 1.23124C9.38425 1.09675 9.13376 1.09675 8.94897 1.23124C7.03843 2.6259 5.11197 3.37071 3.22299 3.44412C2.94119 3.4549 2.7179 3.68691 2.7179 3.96923ZM3.76915 4.46098C5.60065 4.288 7.44343 3.5632 9.25901 2.30097C11.0741 3.5632 12.9174 4.288 14.7489 4.46098V7.74155C14.7494 10.8019 12.9815 13.4593 10.2446 14.5116L9.73484 14.7082C9.42789 14.8263 9.08961 14.8263 8.78368 14.7082C5.7839 13.5543 3.76864 10.6202 3.76915 7.40687V4.46098Z" fill="currentColor"/>
                <path d="M8.1826 10.6602C8.28116 10.7587 8.41462 10.8142 8.55424 10.8142C8.69386 10.8142 8.82732 10.7587 8.92587 10.6602L12.1951 7.39092C12.4005 7.18559 12.4005 6.85297 12.1951 6.64765C11.9898 6.44232 11.6572 6.44232 11.4519 6.64765L8.55424 9.54528L7.06615 8.05668C6.86082 7.85136 6.5282 7.85136 6.32288 8.05668C6.11755 8.26201 6.11755 8.59463 6.32288 8.79995L8.1826 10.6602Z" fill="currentColor"/>
              </svg>
            {%- endif -%}
            {{ section.settings.guarantee_text }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var section = document.querySelector('.hero-banner-wrapper--{{ section.id }}');
    if (!section) return;

    var ctaFunction = {{ section.settings.cta_function | json }};
    var ctaLink = {{ section.settings.cta_url | json }};
    var btns = section.querySelectorAll('[data-hero-btn]');

    btns.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        if (ctaFunction === 'add_to_cart') {
          var productForm = document.querySelector('product-form');
          if (productForm && productForm.form) {
            productForm.form.requestSubmit();
          }
        } else {
          var target = ctaLink || '';
          if (target && target.charAt(0) === '#') {
            var dest = document.querySelector(target);
            if (dest) dest.scrollIntoView({ behavior: 'smooth' });
          } else if (target) {
            window.location.href = target;
          } else {
            var dest = document.querySelector('[id^="ProductInfo-"]');
            if (dest) dest.scrollIntoView({ behavior: 'smooth' });
          }
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#E5F6CB"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Product image (left side)"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg_image",
      "label": "Mobile background image",
      "info": "Replaces the product image on mobile with a full background."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background color",
      "default": "#095946"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#e4f678"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Badge font size",
      "min": 12,
      "max": 30,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Star rating"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "range",
      "id": "star_rating",
      "label": "Rating",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "default": 4.9
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#ffcc00"
    },
    {
      "type": "color",
      "id": "star_empty_color",
      "label": "Empty star color",
      "default": "#ececec"
    },
    {
      "type": "inline_richtext",
      "id": "stars_text",
      "label": "Stars text",
      "default": "<strong>4.9/5</strong> Based on 1,200+ Reviews"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<strong>Support Your Immune System & Gut Health, Naturally.</strong>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 56,
      "step": 1,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "inline_richtext",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "High-potency Oil of Oregano + Black Seed Oil in one clean, easy-to-swallow daily softgel.†"
    },
    {
      "type": "header",
      "content": "CTA button"
    },
    {
      "type": "select",
      "id": "cta_function",
      "label": "Button function",
      "options": [
        { "value": "link", "label": "Link / scroll to section" },
        { "value": "add_to_cart", "label": "Add to cart" }
      ],
      "default": "link"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Shop Huuha Queen® Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link",
      "info": "Leave empty to scroll to product form."
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "Button background color",
      "default": "#095946"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Guarantee"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "30-day money-back guarantee"
    },
    {
      "type": "image_picker",
      "id": "guarantee_icon",
      "label": "Guarantee icon"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
