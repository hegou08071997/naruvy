{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .cr-section {
    width: 100%;
    background: var(--cr-bg, #ffffff);
  }

  .cr-container {
    display: flex;
    align-items: flex-start;
    gap: 80px;
  }

  /* Left column — image */
  .cr-image-col {
    width: 50%;
    flex-shrink: 0;
  }

  .cr-image-col img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--cr-img-radius, 12px);
  }

  .cr-image-placeholder {
    width: 100%;
    aspect-ratio: 5 / 4;
    background: #f0f0f0;
    border-radius: var(--cr-img-radius, 12px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cr-image-placeholder svg {
    width: 60%;
    height: auto;
    opacity: 0.4;
  }

  /* Right column — results */
  .cr-results-col {
    flex: 1;
    min-width: 0;
  }

  .cr-heading {
    font-weight: 600;
    font-size: 28px;
    line-height: 36px;
    margin: 0 0 32px;
    text-align: left;
  }

  .cr-heading strong {
    color: var(--cr-highlight, #6d388b);
  }

  /* Result rows */
  .cr-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cr-row {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 20px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .cr-row:last-child {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .cr-percentage {
    font-weight: 700;
    font-size: 42px;
    line-height: 1;
    color: var(--cr-highlight, #6d388b);
    flex-shrink: 0;
    min-width: 90px;
  }

  .cr-text {
    font-size: 16px;
    line-height: 24px;
    padding-top: 8px;
  }

  .cr-text p {
    margin: 0;
  }

  .cr-text strong {
    font-weight: 600;
  }

  .cr-caption {
    margin-top: 20px;
    font-size: 13px;
    line-height: 18px;
    opacity: 0.6;
  }

  .cr-caption p {
    margin: 0;
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .cr-container {
      flex-direction: column;
      gap: 30px;
    }

    .cr-image-col {
      width: 100%;
      order: -1;
    }

    .cr-results-col {
      width: 100%;
    }

    .cr-heading {
      font-size: 22px;
      line-height: 28px;
      margin-bottom: 24px;
    }

    .cr-percentage {
      font-size: 34px;
      min-width: 72px;
    }

    .cr-text {
      font-size: 14px;
      line-height: 21px;
      padding-top: 4px;
    }

    .cr-row {
      padding: 16px 0;
      gap: 16px;
    }

    .cr-caption {
      font-size: 12px;
    }
  }
</style>

<div
  class="section-{{ section.id }}-padding cr-section"
  style="
    {% if section.settings.bg_color != blank %}--cr-bg: {{ section.settings.bg_color }};{% endif %}
    --cr-highlight: {{ section.settings.highlight_color }};
    --cr-img-radius: {{ section.settings.image_radius }}px;
  "
>
  <div class="page-width">
    <div class="cr-container">
      <div class="cr-image-col">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: '', widths: '400,600,800,1000,1200', sizes: '(min-width: 750px) 50vw, 100vw' }}
        {%- else -%}
          <div class="cr-image-placeholder">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>

      <div class="cr-results-col">
        {%- if section.settings.heading != blank -%}
          <h2 class="cr-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        <div class="cr-rows" data-cr-animate>
          {%- for block in section.blocks -%}
            <div class="cr-row" {{ block.shopify_attributes }}>
              <div class="cr-percentage" data-cr-target="{{ block.settings.percentage }}">0%</div>
              <div class="cr-text">{{ block.settings.text }}</div>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.caption != blank -%}
          <div class="cr-caption">{{ section.settings.caption }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var section = document.querySelector('.cr-section [data-cr-animate]');
    if (!section) return;

    var animated = false;
    var duration = 650;

    function animateCounters() {
      if (animated) return;
      var rect = section.getBoundingClientRect();
      if (rect.top < window.innerHeight - 100) {
        animated = true;
        var els = section.querySelectorAll('[data-cr-target]');
        els.forEach(function (el) {
          var target = parseInt(el.getAttribute('data-cr-target'), 10) || 0;
          var start = 0;
          var startTime = null;

          function step(timestamp) {
            if (!startTime) startTime = timestamp;
            var progress = Math.min((timestamp - startTime) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = Math.round(eased * target);
            el.textContent = current + '%';
            if (progress < 1) {
              requestAnimationFrame(step);
            }
          }

          requestAnimationFrame(step);
        });
      }
    }

    window.addEventListener('scroll', animateCounters, { passive: true });
    animateCounters();
  })();
</script>

{% schema %}
{
  "name": "Customer results",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 12
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "What Customers Report After Using <strong>[BRAND]®</strong>"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#6d388b"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    },
    {
      "type": "richtext",
      "id": "caption",
      "label": "Caption / disclaimer",
      "default": "<p>*Based on customer feedback and post-purchase surveys. Individual results may vary.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "result",
      "name": "Result",
      "limit": 6,
      "settings": [
        {
          "type": "range",
          "id": "percentage",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Percentage",
          "default": 80
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Describe what customers reported here</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer results",
      "blocks": [
        { "type": "result", "settings": { "percentage": 88, "text": "<p>Said they would continue using <strong>[BRAND]®</strong> as part of their wellness routine</p>" } },
        { "type": "result", "settings": { "percentage": 70, "text": "<p>Felt the product supported their heart health and overall wellness goals*</p>" } },
        { "type": "result", "settings": { "percentage": 91, "text": "<p>Noticed better tolerance compared to other supplements, with no discomfort*</p>" } },
        { "type": "result", "settings": { "percentage": 79, "text": "<p>Said they were satisfied with the <strong>overall product quality</strong> and would recommend it to others*</p>" } }
      ]
    }
  ]
}
{% endschema %}
